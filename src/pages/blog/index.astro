---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/readingTime';

const posts = (await getCollection('blog', (post) => {
  return !post.data.draft || !import.meta.env.PROD;
})).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog | Vitchakorn Poonyakanok" description="Writing about Clinical AI, travel medicine, public health informatics, data systems, and cybersecurity.">
  <Navigation />

  <main class="blog-list-container section-alt-bg" style="min-height: 100vh; padding-top: 100px; padding-bottom: 80px;">
    <div class="container-grid">
      <div style="max-width: 800px; margin: 0 auto; width: 100%;">
        <!-- Kicker & Title -->
        <div style="margin-bottom: 2.5rem;">
          <span class="section-kicker t-mono" style="color: var(--accent); font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;">08 · WRITING</span>
          <h1 class="t-hero" style="font-size: clamp(2.5rem, 6vw, 3.75rem); font-weight: 800; line-height: 1.1; margin-top: 0.5rem; margin-bottom: 1rem; color: var(--text-primary);">
            Insights & Notes
          </h1>
          <p style="font-size: 1.0625rem; color: var(--text-secondary); line-height: 1.6; max-width: 600px; margin: 0;">
            Thoughts on bridging travel medicine, public health informatics, medical data privacy, and clinical artificial intelligence.
          </p>
          <div style="width: 100%; height: 1px; background: var(--border); margin-top: 2.5rem;"></div>
        </div>

        <!-- Language Filter Buttons -->
        {posts.length > 0 && (
          <div style="display: flex; gap: 8px; margin-bottom: 2.5rem;" class="blog-filters">
            <button class="filter-btn active" data-lang="all">All</button>
            <button class="filter-btn" data-lang="en">English</button>
            <button class="filter-btn" data-lang="th">ภาษาไทย</button>
          </div>
        )}

        <!-- Post list -->
        {posts.length === 0 ? (
          <div style="padding: 4rem 0; text-align: center; border: 1px dashed var(--border); border-radius: 6px;">
            <p class="t-mono" style="color: var(--text-secondary); margin: 0;">No publications yet. Check back soon!</p>
          </div>
        ) : (
          <div style="display: flex; flex-direction: column; gap: 2.5rem;">
            {posts.map((post) => {
              const postUrl = `/blog/${post.id}`;
              const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              });
              const readingTime = getReadingTime(post.body || '');
              const lang = post.data.lang || 'en';
              
              return (
                <article class="blog-item" data-post-lang={lang} style="position: relative;">
                  <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <!-- Date, Lang, Reading Time & Tags -->
                    <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                      <span style="font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; color: var(--accent); border: 1px solid var(--border); padding: 1px 5px; border-radius: 4px; background: var(--bg-card);">{lang}</span>
                      <span style="color: var(--text-quaternary); font-size: 0.75rem;">•</span>
                      <time datetime={post.data.pubDate.toISOString()} class="t-mono" style="font-size: 0.75rem; color: var(--text-secondary); font-weight: 500;">
                        {formattedDate}
                      </time>
                      <span style="color: var(--text-quaternary); font-size: 0.75rem;">•</span>
                      <span class="t-mono" style="font-size: 0.75rem; color: var(--text-secondary);">{readingTime} min read</span>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <>
                          <span style="color: var(--text-quaternary); font-size: 0.75rem;">•</span>
                          <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                            {post.data.tags.map(tag => (
                              <span class="t-mono" style="font-size: 0.6875rem; color: var(--accent); font-weight: 600; text-transform: uppercase;">
                                {tag}
                              </span>
                            ))}
                          </div>
                        </>
                      )}
                    </div>

                    <!-- Title -->
                    <h2 style="font-size: clamp(1.25rem, 3vw, 1.625rem); font-weight: 700; margin: 0; line-height: 1.25;">
                      <a href={postUrl} class="blog-link" style="color: var(--text-primary); text-decoration: none; display: inline-block; transition: color 0.15s ease;">
                        {post.data.title}
                      </a>
                    </h2>

                    <!-- Description -->
                    <p style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.6; margin: 0; max-width: 720px;">
                      {post.data.description}
                    </p>

                    <!-- Read More Link -->
                    <div>
                      <a href={postUrl} class="t-mono" style="font-size: 0.75rem; color: var(--accent); text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; text-transform: uppercase;">
                        Read Article
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                      </a>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .blog-item {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }
  .blog-item:last-child {
    border-bottom: none;
  }
  .blog-link:hover {
    color: var(--accent) !important;
  }
  
  .filter-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.15s ease;
    text-transform: uppercase;
  }
  .filter-btn:hover {
    color: var(--text-primary);
    border-color: var(--text-secondary);
  }
  .filter-btn.active {
    color: #fff;
    background: var(--accent);
    border-color: var(--accent);
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.blog-item');
  
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Toggle active class
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const filterLang = btn.getAttribute('data-lang');
      
      items.forEach(item => {
        const itemLang = item.getAttribute('data-post-lang');
        if (filterLang === 'all' || itemLang === filterLang) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
