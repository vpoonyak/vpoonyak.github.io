---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | Vitchakorn Poonyakanok" description="Get in touch for collaborations in clinical AI, travel medicine, and public health data systems." canonicalUrl="https://vitchakorn.com/contact/">
  <Navigation />
  <Contact standalone />
  <Footer />
</Layout>

<script>
  // This page shows only the Contact section (no scroll-spy like the
  // homepage), so mark it active directly to get the same accent-tinted
  // section number/heading treatment Contact has when scrolled into view
  // on the homepage.
  document.body.dataset.activeSection = 'contact';

  // Contact.astro's .fade-in elements start at opacity:0 and only get
  // .visible from the homepage's scroll-reveal script -- this page has no
  // such script, so reveal them directly instead of leaving them invisible.
  document.querySelectorAll('.fade-in').forEach((el) => el.classList.add('visible'));
</script>
