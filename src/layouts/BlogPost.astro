---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  canonicalUrl?: string;
  readingTime?: number;
  lang?: 'en' | 'th';
  headings?: Heading[];
}

const { title, description, pubDate, updatedDate, heroImage, tags, canonicalUrl, readingTime, lang = 'en', headings = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Auto jump-nav: only worth showing once a post has enough h2 sections to actually need one.
const sectionHeadings = headings.filter((h) => h.depth === 2);
const showJumpNav = sectionHeadings.length >= 3;

const siteUrl = 'https://vitchakorn.com';
const articleImage = heroImage
  ? (heroImage.startsWith('http') ? heroImage : `${siteUrl}${heroImage}`)
  : `${siteUrl}/pic/og-card.jpg`;

// The hero container is always cropped to 16:9 (see .blog-hero-image-container
// below) regardless of the source file's native dimensions, so declare the
// og:image size to match that displayed aspect ratio rather than the
// homepage default's 1200x1200 square.
const ogImageWidth = heroImage ? 1200 : undefined;
const ogImageHeight = heroImage ? 675 : undefined;
const ogImageAlt = heroImage ? `${title} — cover image` : undefined;
const keywords = tags && tags.length > 0 ? tags.join(', ') : undefined;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: articleImage,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  inLanguage: lang,
  author: { '@type': 'Person', name: 'Vitchakorn Poonyakanok', url: siteUrl },
  publisher: { '@type': 'Person', name: 'Vitchakorn Poonyakanok' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
};
---

<Layout title={`${title} | Vitchakorn Poonyakanok`} description={description} keywords={keywords} image={heroImage} imageWidth={ogImageWidth} imageHeight={ogImageHeight} imageAlt={ogImageAlt} canonicalUrl={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <Navigation compact backHref="/blog" backLabel="Blog" />

  <main class="blog-post-container section-alt-bg" style="min-height: 100vh; padding-top: 64px; padding-bottom: 80px;">
    <div class="container-grid">
      <div class={showJumpNav ? "blog-layout with-sidebar" : "blog-layout"}>
        {showJumpNav && (
          <div class="side-rail">
            <nav class="jump-nav t-mono" aria-label="Section navigation">
              {sectionHeadings.map((h, i) => (
                <a href={`#${h.slug}`}>
                  <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="toc-text">{h.text}</span>
                </a>
              ))}
            </nav>

            <div class="rail-legend t-mono">
              <p class="rail-legend-title">สัญลักษณ์</p>
              <div class="rail-legend-item"><span class="rail-legend-swatch todo"></span>ต้องทำ</div>
              <div class="rail-legend-item"><span class="rail-legend-swatch problem"></span>ปัญหาที่อาจเจอ</div>
              <div class="rail-legend-item"><span class="rail-legend-swatch lesson"></span>บทเรียน</div>
              <div class="rail-legend-item"><span class="rail-legend-swatch case"></span>เคสจริง</div>
            </div>
          </div>
        )}
      <article class="blog-post-article">
        {heroImage && (
          <div class="blog-hero-image-container" style="position: relative; border-radius: 6px; overflow: hidden; margin-bottom: 2.5rem; border: 1px solid var(--border); aspect-ratio: 16/9;">
            <img src={heroImage} alt={title} style="width: 100%; height: 100%; object-fit: cover;" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 55%, var(--bg-card) 100%); pointer-events: none;"></div>
          </div>
        )}

        <!-- Header -->
        <header class="blog-post-header" style="margin-bottom: 2.5rem;">
          <div class="blog-meta t-mono" style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
            <span style="font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; color: var(--accent); border: 1px solid var(--border); padding: 2px 6px; border-radius: 4px; background: var(--bg-card);">{lang}</span>
            <span style="color: var(--text-quaternary);">•</span>
            <span>{formattedDate}</span>
            {updatedDate && (
              <>
                <span style="color: var(--text-quaternary);">•</span>
                <span>Updated: {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              </>
            )}
            {readingTime && (
              <>
                <span style="color: var(--text-quaternary);">•</span>
                <span>{readingTime} min read</span>
              </>
            )}
          </div>
          
          <h1 class="t-hero" style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; line-height: 1.15; color: var(--text-primary); margin: 0 0 1.5rem 0;">
            {title}
          </h1>

          {tags && tags.length > 0 && (
            <div class="blog-tags" style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1.5rem;">
              {tags.map((tag) => (
                <span class="badge t-mono" style="font-size: 0.6875rem; padding: 4px 8px; border-radius: 4px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary); font-weight: 500;">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <div style="width: 100%; height: 1px; background: var(--border); margin-top: 1rem;"></div>
        </header>

        <!-- Content -->
        <div class="blog-content markdown-body" lang={lang} style="font-size: 1.0625rem; line-height: 1.75; color: var(--text-primary);">
          <slot />
        </div>
      </article>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Markdown styling custom for article reading layout */
  .blog-layout {
    max-width: 720px;
    margin: 0 auto;
  }

  .blog-layout.with-sidebar {
    max-width: 960px;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .blog-layout.with-sidebar {
      grid-template-columns: 1fr;
      /* Stacked single-column layout: the jump-nav pill bar already has its
         own border/margin as a visual divider, so the grid's column-gap
         (meant for the desktop sidebar split) would double up as a row-gap
         here and add a redundant ~40px. */
      gap: 0;
    }
  }

  .blog-post-article {
    min-width: 0;
  }

  .markdown-body {
    word-break: break-word;
  }

  .markdown-body p {
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .markdown-body h2 {
    font-size: 1.625rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    line-height: 1.3;
    letter-spacing: -0.015em;
  }

  .markdown-body h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .markdown-body ul, .markdown-body ol {
    margin-top: 0;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .markdown-body li {
    margin-bottom: 0.5rem;
  }

  .markdown-body a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }

  .markdown-body a:hover {
    border-bottom-color: var(--accent);
  }

  .markdown-body blockquote {
    margin: 1.5rem 0;
    padding-left: 1.25rem;
    border-left: 4px solid var(--accent);
    color: var(--text-secondary);
    font-style: italic;
  }

  .markdown-body pre {
    background: var(--bg-code) !important;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
  }

  .markdown-body code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    background: var(--bg-code);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .markdown-body pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    border: none;
  }

  .markdown-body img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 2rem 0 0.5rem;
    border: 1px solid var(--border);
  }

  /* An image with no blank line before the next line (`![]()` immediately
     followed by `*caption*`) lands in the same <p> as an inline sibling, not
     a separate paragraph — style that caption tight under the image instead
     of reading as body text. */
  .markdown-body img + em {
    display: block;
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    text-align: center;
    font-style: italic;
  }

  .markdown-body hr {
    height: 1px;
    border: none;
    background: var(--border);
    margin: 2.5rem 0;
  }

  /* Thai typography adjustments for spacing and word-breaking */
  .markdown-body[lang="th"] {
    line-height: 1.8;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  /* Side rail: stats + clickable episode "timeline" + legend on desktop, part-stepper chips on mobile */
  .side-rail {
    z-index: 5;
    min-width: 0;
    max-width: 100%;
  }

  @media (min-width: 901px) {
    .side-rail {
      position: sticky;
      top: 64px;
      max-height: calc(100dvh - 84px);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding-right: 4px;
    }
  }

  /* Legend */
  .rail-legend { display: none; }
  @media (min-width: 901px) {
    .rail-legend {
      display: block;
      border-top: 1px solid var(--border);
      padding-top: 1rem;
    }
    .rail-legend-title {
      margin: 0 0 0.65rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }
    .rail-legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 0.6rem;
    }
    .rail-legend-swatch {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
    }
    .rail-legend-swatch.todo { background: var(--accent); }
    .rail-legend-swatch.problem { background: var(--stress); }
    .rail-legend-swatch.lesson { background: var(--success); }
    .rail-legend-swatch.case { background: var(--text-tertiary); }
  }

  /* Part-stepper / TOC */
  .jump-nav {
    position: sticky;
    top: 64px;
    z-index: 5;
    display: flex;
    gap: 4px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 8px 0;
    margin-bottom: 1rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .jump-nav::-webkit-scrollbar { display: none; }
  .jump-nav a {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    white-space: nowrap;
    padding: 7px 11px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .jump-nav .toc-num {
    font-size: 0.75rem;
    color: var(--text-quaternary);
  }
  .jump-nav a:hover, .jump-nav a:focus-visible {
    color: var(--accent);
    border-color: var(--accent-border);
  }

  .jump-nav a.active {
    color: var(--accent);
    border-color: var(--accent-border);
    background: var(--accent-muted);
  }
  .jump-nav a.active .toc-num {
    color: var(--accent);
  }

  @media (min-width: 901px) {
    .side-rail .jump-nav {
      position: static;
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
      overflow-x: visible;
      max-height: none;
      overflow-y: visible;
      padding: 0;
      margin-bottom: 0;
      background: transparent;
      border-bottom: none;
      border-left: 1px solid var(--border);
    }
    .side-rail .jump-nav a {
      white-space: normal;
      border: none;
      border-left: 2px solid transparent;
      border-radius: 0;
      background: transparent;
      padding: 6px 0 6px 14px;
      margin-left: -1px;
      line-height: 1.35;
      align-items: flex-start;
    }
    .side-rail .jump-nav .toc-num {
      flex: none;
      margin-top: 0.1em;
    }
    .side-rail .jump-nav a:hover,
    .side-rail .jump-nav a:focus-visible,
    .side-rail .jump-nav a.active {
      border-left-color: var(--accent);
      background: transparent;
    }
    .side-rail .jump-nav a.active {
      color: var(--accent);
      font-weight: 700;
    }
  }

  /* Notion-style two/three-column layout, usable directly in markdown as raw HTML */
  .markdown-body .columns {
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: 1.25rem;
    margin: 1.75rem 0;
  }
  @media (max-width: 640px) {
    .markdown-body .columns { grid-template-columns: 1fr; }
  }
  .markdown-body .columns > * { min-width: 0; }

  /* GFM tables */
  .markdown-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 0.9375rem;
  }
  .markdown-body th, .markdown-body td {
    border: 1px solid var(--border);
    padding: 8px 12px;
    text-align: left;
    vertical-align: top;
  }
  .markdown-body th {
    background: var(--bg-card);
    font-weight: 600;
    color: var(--text-primary);
  }
  .markdown-body tr:nth-child(even) td {
    background: var(--bg-card);
  }

  /* GFM task list checkboxes */
  .markdown-body li.task-list-item {
    list-style: none;
    margin-left: -1.5rem;
    padding-left: 0.25rem;
  }
  .markdown-body li.task-list-item input[type="checkbox"] {
    margin-right: 8px;
    accent-color: var(--accent);
  }

  /* Callout boxes: todo / problem / case / lesson — colored header bar + icon */
  .markdown-body .callout {
    margin: 1.75rem 0;
    padding: 0 1.25rem 1rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    overflow: hidden;
  }
  .markdown-body .callout > :last-child { margin-bottom: 0; }
  .markdown-body .callout-label {
    display: flex;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 -1.25rem 0.85rem;
    padding: 11px 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .markdown-body .callout-label::before {
    display: inline-block;
    margin-right: 7px;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
  }
  .markdown-body .callout.todo .callout-label {
    background: var(--accent-muted);
    color: var(--accent);
  }
  .markdown-body .callout.todo .callout-label::before { content: "✓"; }
  .markdown-body .callout.problem .callout-label {
    background: var(--stress-muted);
    color: var(--stress);
  }
  .markdown-body .callout.problem .callout-label::before { content: "▲"; }
  .markdown-body .callout.lesson .callout-label {
    background: var(--success-muted);
    color: var(--success);
  }
  .markdown-body .callout.lesson .callout-label::before { content: "✦"; }
  .markdown-body .callout.case .callout-label {
    background: var(--bg-card-hover);
    color: var(--text-tertiary);
  }
  .markdown-body .callout.case .callout-label::before { content: "◆"; }

  /* Lightweight flow diagrams (แผนผัง) — theme-aware, no image assets needed */
  .markdown-body .flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9375rem;
  }
  .markdown-body .flow + .flow { margin-top: 0.6rem; }
  .markdown-body .flow-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    flex: none;
    width: 100%;
    margin-bottom: 0.2rem;
  }
  .markdown-body .flow-step {
    padding: 7px 13px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-primary);
    white-space: nowrap;
  }
  .markdown-body .flow-step.highlight {
    border-color: var(--accent-border);
    background: var(--accent-muted);
    color: var(--accent);
    font-weight: 600;
  }
  .markdown-body .flow-arrow {
    color: var(--text-quaternary);
  }
  @media (max-width: 640px) {
    .markdown-body .flow { font-size: 0.8125rem; }
    .markdown-body .flow-step {
      white-space: normal;
      max-width: 100%;
    }
  }

  /* Belt-and-suspenders: nothing inside the article should ever be able to
     force the page wider than the viewport on mobile (long unbreakable pills,
     wide tables, etc.) */
  .markdown-body table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  @media (max-width: 900px) {
    .blog-post-article, .markdown-body, .markdown-body .flow, .markdown-body pre {
      max-width: 100%;
    }
  }
</style>

{showJumpNav && (
  <script>
    const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.jump-nav a'));
    const sections = navLinks
      .map((link) => document.getElementById(decodeURIComponent(link.hash.slice(1))))
      .filter((el): el is HTMLElement => el !== null);

    if (sections.length > 0) {
      const setActive = (id: string) => {
        navLinks.forEach((link) => {
          link.classList.toggle('active', decodeURIComponent(link.hash.slice(1)) === id);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible.length > 0) {
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '-100px 0px -70% 0px', threshold: 0 }
      );

      sections.forEach((section) => observer.observe(section));
      setActive(sections[0].id);
    }
  </script>
)}
