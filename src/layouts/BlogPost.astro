---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import thaiWordJoinsData from '../data/thai-word-joins.json';

// Single source of truth shared with scripts/apply-thai-word-joins.mjs (the
// real postbuild step) -- the interactive demo in the Thai typography post
// reads this exact list, so it can never silently drift from what actually
// ships.
const approvedThaiWords: string[] = thaiWordJoinsData.words;

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  canonicalUrl?: string;
  readingTime?: number;
  lang?: 'en' | 'th';
  headings?: Heading[];
  translationSlug?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags, canonicalUrl, readingTime, lang = 'en', headings = [], translationSlug } = Astro.props;

const otherLangLabel = lang === 'en' ? 'TH' : 'EN';
const switcherText = lang === 'en' ? 'Read in Thai' : 'อ่านภาษาอังกฤษ';

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Auto jump-nav: only worth showing once a post has enough h2 sections to actually need one.
const sectionHeadings = headings.filter((h) => h.depth === 2);
const showJumpNav = sectionHeadings.length >= 3;

// Sidebar legend explaining the callout swatch colors -- must match the
// post's own language, not just default to Thai regardless of `lang`.
const legendText = lang === 'en'
  ? { title: 'Legend', todo: 'Action item', problem: 'Potential problem', lesson: 'Lesson', case: 'Real case' }
  : { title: 'สัญลักษณ์', todo: 'ต้องทำ', problem: 'ปัญหาที่อาจเจอ', lesson: 'บทเรียน', case: 'เคสจริง' };

const siteUrl = 'https://vitchakorn.com';
const articleImage = heroImage
  ? (heroImage.startsWith('http') ? heroImage : `${siteUrl}${heroImage}`)
  : `${siteUrl}/pic/og-card.jpg`;

// og:image should describe the source file's own dimensions (roughly 16:9
// for hero images so far), not the in-page banner crop below (which uses a
// wider/shorter ratio purely for the on-page reading layout) -- external
// crawlers do their own cropping from the declared size regardless of this
// page's CSS.
const ogImageWidth = heroImage ? 1200 : undefined;
const ogImageHeight = heroImage ? 675 : undefined;
const ogImageAlt = heroImage ? `${title} (cover image)` : undefined;
const keywords = tags && tags.length > 0 ? tags.join(', ') : undefined;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: articleImage,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  inLanguage: lang,
  author: { '@type': 'Person', name: 'Vitchakorn Poonyakanok', url: siteUrl },
  publisher: { '@type': 'Person', name: 'Vitchakorn Poonyakanok' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
};
---

<Layout title={`${title} | Vitchakorn Poonyakanok`} description={description} keywords={keywords} image={heroImage} imageWidth={ogImageWidth} imageHeight={ogImageHeight} imageAlt={ogImageAlt} canonicalUrl={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <Navigation compact backHref="/blog" backLabel="Blog" />

  <main class="blog-post-container section-alt-bg" style="min-height: 100vh; padding-top: 64px; padding-bottom: 80px;">
    <div class="container-grid">
      <div class={showJumpNav ? "blog-layout with-sidebar" : "blog-layout"}>
        {showJumpNav && (
          <div class="side-rail">
            <nav class="jump-nav t-mono" aria-label="Section navigation">
              {sectionHeadings.map((h, i) => (
                <a href={`#${h.slug}`}>
                  <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="toc-text">{h.text}</span>
                </a>
              ))}
            </nav>

            <div class="rail-legend t-mono">
              <p class="rail-legend-title">{legendText.title}</p>
              <div class="rail-legend-item"><span class="rail-legend-swatch todo"></span>{legendText.todo}</div>
              <div class="rail-legend-item"><span class="rail-legend-swatch problem"></span>{legendText.problem}</div>
              <div class="rail-legend-item"><span class="rail-legend-swatch lesson"></span>{legendText.lesson}</div>
              <div class="rail-legend-item"><span class="rail-legend-swatch case"></span>{legendText.case}</div>
            </div>
          </div>
        )}
      <article class="blog-post-article">
        {heroImage && (
          <div class="blog-hero-image-container" style="position: relative; border-radius: 6px; overflow: hidden; margin-bottom: 2.5rem; border: 1px solid var(--border); aspect-ratio: 5/2;">
            <img src={heroImage} alt={title} style="width: 100%; height: 100%; object-fit: cover; object-position: center top;" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 55%, var(--bg-card) 100%); pointer-events: none;"></div>
          </div>
        )}

        <!-- Header -->
        <header class="blog-post-header" style="margin-bottom: 2.5rem;">
          <div class="blog-meta t-mono" style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
            <span style="font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; color: var(--accent); border: 1px solid var(--border); padding: 2px 6px; border-radius: 4px; background: var(--bg-card);">{lang}</span>
            {translationSlug && (
              <a
                href={`/blog/${translationSlug}/`}
                class="lang-switcher t-mono"
                title={switcherText}
                style="font-size: 0.6875rem; font-weight: 600; padding: 2px 8px; border-radius: 4px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary); text-decoration: none; display: inline-flex; align-items: center; gap: 4px;"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>{otherLangLabel}
              </a>
            )}
            <span style="color: var(--text-quaternary);">•</span>
            <span>{formattedDate}</span>
            {updatedDate && (
              <>
                <span style="color: var(--text-quaternary);">•</span>
                <span>Updated: {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              </>
            )}
            {readingTime && (
              <>
                <span style="color: var(--text-quaternary);">•</span>
                <span>{readingTime} min read</span>
              </>
            )}
          </div>
          
          <h1 class="t-hero" style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; line-height: 1.15; color: var(--text-primary); margin: 0 0 1.5rem 0;">
            {title}
          </h1>

          {tags && tags.length > 0 && (
            <div class="blog-tags" style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1.5rem;">
              {tags.map((tag) => (
                <span class="badge t-mono" style="font-size: 0.6875rem; padding: 4px 8px; border-radius: 4px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary); font-weight: 500;">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <div style="width: 100%; height: 1px; background: var(--border); margin-top: 1rem;"></div>
        </header>

        <!-- Content -->
        <div class="blog-content markdown-body" lang={lang} style="font-size: 1.0625rem; line-height: 1.75; color: var(--text-primary);">
          <slot />
        </div>
      </article>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .lang-switcher:hover {
    border-color: var(--accent-border) !important;
    color: var(--accent) !important;
  }

  /* Markdown styling custom for article reading layout */
  .blog-layout {
    max-width: 720px;
    margin: 0 auto;
  }

  .blog-layout.with-sidebar {
    max-width: 960px;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .blog-layout.with-sidebar {
      grid-template-columns: 1fr;
      /* Stacked single-column layout: the jump-nav pill bar already has its
         own border/margin as a visual divider, so the grid's column-gap
         (meant for the desktop sidebar split) would double up as a row-gap
         here and add a redundant ~40px. */
      gap: 0;
    }
  }

  .blog-post-article {
    min-width: 0;
  }

  .markdown-body {
    word-break: break-word;
  }

  .markdown-body p {
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  /* Clicking a jump-nav link (or any #anchor to a heading) would otherwise
     land the heading right at the viewport top, hidden under the fixed
     compact nav — and on mobile/tablet, also under the sticky jump-nav pill
     bar sitting right below it. */
  .markdown-body h2,
  .markdown-body h3 {
    scroll-margin-top: 130px;
  }

  @media (min-width: 901px) {
    /* Desktop: the jump-nav becomes a static sidebar (no longer sticky over
       content), so headings only need to clear the fixed nav bar itself. */
    .markdown-body h2,
    .markdown-body h3 {
      scroll-margin-top: 76px;
    }
  }

  .markdown-body h2 {
    font-size: 1.625rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    line-height: 1.3;
    letter-spacing: -0.015em;
  }

  .markdown-body h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .markdown-body ul, .markdown-body ol {
    margin-top: 0;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .markdown-body li {
    margin-bottom: 0.5rem;
  }

  .markdown-body a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }

  .markdown-body a:hover {
    border-bottom-color: var(--accent);
  }

  .markdown-body blockquote {
    margin: 1.5rem 0;
    padding-left: 1.25rem;
    border-left: 4px solid var(--accent);
    color: var(--text-secondary);
    font-style: italic;
  }

  .markdown-body pre {
    background: var(--bg-code) !important;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
  }

  .markdown-body code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    background: var(--bg-code);
    color: #eb5757;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .markdown-body pre code {
    background: transparent;
    color: inherit;
    padding: 0;
    border-radius: 0;
    border: none;
  }

  .markdown-body img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 2rem 0 0.5rem;
    border: 1px solid var(--border);
  }

  /* An image with no blank line before the next line (`![]()` immediately
     followed by `*caption*`) lands in the same <p> as an inline sibling, not
     a separate paragraph — style that caption tight under the image instead
     of reading as body text. */
  .markdown-body img + em {
    display: block;
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    text-align: center;
    font-style: italic;
  }

  .markdown-body hr {
    height: 1px;
    border: none;
    background: var(--border);
    margin: 2.5rem 0;
  }

  /* Thai typography adjustments for spacing and word-breaking */
  .markdown-body[lang="th"] {
    line-height: 1.8;
    overflow-wrap: break-word;
  }

  /* Side rail: stats + clickable episode "timeline" + legend on desktop, part-stepper chips on mobile */
  .side-rail {
    z-index: 5;
    min-width: 0;
    max-width: 100%;
  }

  @media (min-width: 901px) {
    .side-rail {
      position: sticky;
      top: 64px;
      max-height: calc(100dvh - 84px);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding-right: 4px;
    }
  }

  /* Legend */
  .rail-legend { display: none; }
  @media (min-width: 901px) {
    .rail-legend {
      display: block;
      border-top: 1px solid var(--border);
      padding-top: 1rem;
    }
    .rail-legend-title {
      margin: 0 0 0.65rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }
    .rail-legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 0.6rem;
    }
    .rail-legend-swatch {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
    }
    .rail-legend-swatch.todo { background: var(--accent); }
    .rail-legend-swatch.problem { background: var(--stress); }
    .rail-legend-swatch.lesson { background: var(--success); }
    .rail-legend-swatch.case { background: var(--text-tertiary); }
  }

  /* Part-stepper / TOC */
  .jump-nav {
    position: sticky;
    top: 64px;
    z-index: 5;
    display: flex;
    gap: 4px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 8px 0;
    margin-bottom: 1rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .jump-nav::-webkit-scrollbar { display: none; }
  .jump-nav a {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    white-space: nowrap;
    padding: 7px 11px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .jump-nav .toc-num {
    font-size: 0.75rem;
    color: var(--text-quaternary);
  }
  .jump-nav a:hover, .jump-nav a:focus-visible {
    color: var(--accent);
    border-color: var(--accent-border);
  }

  .jump-nav a.active {
    color: var(--accent);
    border-color: var(--accent-border);
    background: var(--accent-muted);
  }
  .jump-nav a.active .toc-num {
    color: var(--accent);
  }

  @media (min-width: 901px) {
    .side-rail .jump-nav {
      position: static;
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
      overflow-x: visible;
      max-height: none;
      overflow-y: visible;
      padding: 0;
      margin-bottom: 0;
      background: transparent;
      border-bottom: none;
      border-left: 1px solid var(--border);
    }
    .side-rail .jump-nav a {
      white-space: normal;
      border: none;
      border-left: 2px solid transparent;
      border-radius: 0;
      background: transparent;
      padding: 6px 0 6px 14px;
      margin-left: -1px;
      line-height: 1.35;
      align-items: flex-start;
    }
    .side-rail .jump-nav .toc-num {
      flex: none;
      margin-top: 0.1em;
    }
    .side-rail .jump-nav a:hover,
    .side-rail .jump-nav a:focus-visible,
    .side-rail .jump-nav a.active {
      border-left-color: var(--accent);
      background: transparent;
    }
    .side-rail .jump-nav a.active {
      color: var(--accent);
      font-weight: 700;
    }
  }

  /* Notion-style two/three-column layout, usable directly in markdown as raw HTML */
  .markdown-body .columns {
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: 1.25rem;
    margin: 1.75rem 0;
  }
  @media (max-width: 640px) {
    .markdown-body .columns { grid-template-columns: 1fr; }
  }
  .markdown-body .columns > * { min-width: 0; }

  /* GFM tables */
  .markdown-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 0.9375rem;
  }
  .markdown-body th, .markdown-body td {
    border: 1px solid var(--border);
    padding: 8px 12px;
    text-align: left;
    vertical-align: top;
  }
  .markdown-body th {
    background: var(--bg-card);
    font-weight: 600;
    color: var(--text-primary);
  }
  .markdown-body tr:nth-child(even) td {
    background: var(--bg-card);
  }

  /* GFM task list checkboxes */
  .markdown-body li.task-list-item {
    list-style: none;
    margin-left: -1.5rem;
    padding-left: 0.25rem;
  }
  .markdown-body li.task-list-item input[type="checkbox"] {
    margin-right: 8px;
    accent-color: var(--accent);
  }

  /* Callout boxes: todo / problem / case / lesson — colored header bar + icon */
  .markdown-body .callout {
    margin: 1.75rem 0;
    padding: 0 1.25rem 1rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    overflow: hidden;
  }
  .markdown-body .callout > :last-child { margin-bottom: 0; }
  .markdown-body .callout-label {
    display: flex;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 -1.25rem 0.85rem;
    padding: 11px 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .markdown-body .callout-label::before {
    display: inline-block;
    margin-right: 7px;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
  }
  .markdown-body .callout.todo .callout-label {
    background: var(--accent-muted);
    color: var(--accent);
  }
  .markdown-body .callout.todo .callout-label::before { content: "✓"; }
  .markdown-body .callout.problem .callout-label {
    background: var(--stress-muted);
    color: var(--stress);
  }
  .markdown-body .callout.problem .callout-label::before { content: "▲"; }
  .markdown-body .callout.lesson .callout-label {
    background: var(--success-muted);
    color: var(--success);
  }
  .markdown-body .callout.lesson .callout-label::before { content: "✦"; }
  .markdown-body .callout.case .callout-label {
    background: var(--bg-card-hover);
    color: var(--text-tertiary);
  }
  .markdown-body .callout.case .callout-label::before { content: "◆"; }

  /* Lightweight flow diagrams (แผนผัง) — theme-aware, no image assets needed */
  .markdown-body .flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9375rem;
  }
  .markdown-body .flow + .flow { margin-top: 0.6rem; }
  .markdown-body .flow-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    flex: none;
    width: 100%;
    margin-bottom: 0.2rem;
  }
  .markdown-body .flow-step {
    padding: 7px 13px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-primary);
    white-space: nowrap;
  }
  .markdown-body .flow-step.highlight {
    border-color: var(--accent-border);
    background: var(--accent-muted);
    color: var(--accent);
    font-weight: 600;
  }
  .markdown-body .flow-arrow {
    color: var(--text-quaternary);
  }
  @media (max-width: 640px) {
    .markdown-body .flow { font-size: 0.8125rem; }
    .markdown-body .flow-step {
      white-space: normal;
      max-width: 100%;
    }
  }

  /* Interactive "before/after" word-wrap demo (used in the Thai typography
     post). Purely presentational -- the toggle logic lives in the gated
     script below, a no-op on any page without a [data-thai-demo] element. */
  .markdown-body .thai-demo {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    margin: 1.75rem 0;
    background: var(--bg-card);
  }
  .markdown-body .thai-demo-input-label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin-bottom: 0.4rem;
  }
  .markdown-body .thai-demo-input {
    display: block;
    width: 100%;
    box-sizing: border-box;
    resize: vertical;
    min-height: 5.5rem;
    margin-bottom: 1rem;
    padding: 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.9375rem;
    line-height: 1.7;
  }
  .markdown-body .thai-demo-input:focus {
    outline: none;
    border-color: var(--accent-border);
  }
  .markdown-body .thai-demo-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 1rem;
  }
  .markdown-body .thai-demo-tab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    padding: 6px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    line-height: 1.4;
  }
  .markdown-body .thai-demo-tab:hover { border-color: var(--accent-border); }
  .markdown-body .thai-demo-tab.active {
    border-color: var(--accent-border);
    background: var(--accent-muted);
    color: var(--accent);
    font-weight: 600;
  }
  .markdown-body .thai-demo-box {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem;
    background: var(--bg);
    max-width: 420px;
  }
  .markdown-body .thai-demo-text {
    margin: 0;
    font-size: 1rem;
    line-height: 1.8;
  }
  .markdown-body .thai-demo-caption {
    margin: 0.75rem 0 0;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  /* Belt-and-suspenders: nothing inside the article should ever be able to
     force the page wider than the viewport on mobile (long unbreakable pills,
     wide tables, etc.) */
  .markdown-body table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  @media (max-width: 900px) {
    .blog-post-article, .markdown-body, .markdown-body .flow, .markdown-body pre {
      max-width: 100%;
    }
  }
</style>

{showJumpNav && (
  <script>
    const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.jump-nav a'));
    const sections = navLinks
      .map((link) => document.getElementById(decodeURIComponent(link.hash.slice(1))))
      .filter((el): el is HTMLElement => el !== null);

    if (sections.length > 0) {
      const setActive = (id: string) => {
        navLinks.forEach((link) => {
          link.classList.toggle('active', decodeURIComponent(link.hash.slice(1)) === id);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible.length > 0) {
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '-100px 0px -70% 0px', threshold: 0 }
      );

      sections.forEach((section) => observer.observe(section));
      setActive(sections[0].id);
    }
  </script>
)}

<script>
  // Only show a legend swatch for a callout type this specific post
  // actually uses -- a post that never has a "todo" callout shouldn't list
  // one. No-op (a handful of querySelector calls) on any post without a
  // .rail-legend at all.
  const legend = document.querySelector<HTMLElement>('.rail-legend');
  if (legend) {
    const types = ['todo', 'problem', 'lesson', 'case'];
    let anyUsed = false;
    for (const type of types) {
      const used = document.querySelector(`.markdown-body .callout.${type}`) !== null;
      if (used) anyUsed = true;
      const swatch = legend.querySelector(`.rail-legend-swatch.${type}`);
      const item = swatch?.closest<HTMLElement>('.rail-legend-item');
      if (item && !used) item.style.display = 'none';
    }
    if (!anyUsed) legend.style.display = 'none';
  }
</script>

{/* define:vars forces this script inline/unbundled -- fine for handing off
    plain data, but it means a bare `import('nlpo3-newmm-typescript')` inside
    it would never get resolved/code-split by Vite. So this block only
    exists to hand the build-time word list to the real (bundled) script
    below via a global, keeping thai-word-joins.json as the single source of
    truth without breaking the dynamic import in the demo's "full tokenizer"
    tab. */}
<script define:vars={{ approvedThaiWords }}>
  window.__approvedThaiWords = approvedThaiWords;
</script>

<script>
  // Gated on element presence -- a no-op (single querySelectorAll, no
  // listeners attached) on every page except the one post that embeds a
  // [data-thai-demo] block.
  const demos = document.querySelectorAll<HTMLElement>('[data-thai-demo]');
  const approvedThaiWords: string[] = (window as any).__approvedThaiWords || [];
  const sortedApprovedWords = [...approvedThaiWords].sort((a, b) => b.length - a.length);
  const graphemeSegmenter = new Intl.Segmenter(undefined, { granularity: 'grapheme' });

  // Split into user-perceived characters, not raw UTF-16 code units --
  // word.split('') would separate a base consonant from its own combining
  // vowel/tone marks (ข + ั + ้ is ONE visual unit).
  function toGraphemeClusters(word: string): string[] {
    return Array.from(graphemeSegmenter.segment(word), (s) => s.segment);
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  type Segment = { type: 'text' | 'nowrap'; value: string };

  // Mirrors scripts/lib/thai-html-walk.mjs's segmentThaiText exactly. Wraps
  // matched words (and every Maiyamok ๆ + its preceding character) in
  // `<span style="white-space:nowrap">` spans rather than inserting U+2060
  // WORD JOINER characters. An earlier version used WORD JOINER and had a
  // real bug: injecting it mid-word could confuse Chromium's Thai
  // dictionary-based line-breaker badly enough to also lose the (valid,
  // unrelated) break opportunity *before* the joined word -- observed
  // splitting "อ่าน" into "อ่า"+"น" purely because "รายละเอียด" right after
  // it had been joined. Real CSS layout (white-space:nowrap) doesn't have
  // that failure mode.
  function segmentThaiText(text: string, words: string[]): Segment[] {
    let segments: Segment[] = [{ type: 'text', value: text }];
    for (const word of words) {
      const next: Segment[] = [];
      for (const seg of segments) {
        if (seg.type !== 'text' || !seg.value.includes(word)) {
          next.push(seg);
          continue;
        }
        const parts = seg.value.split(word);
        parts.forEach((part, i) => {
          if (part) next.push({ type: 'text', value: part });
          if (i < parts.length - 1) next.push({ type: 'nowrap', value: word });
        });
      }
      segments = next;
    }

    // Maiyamok (ๆ, U+0E46) must never start a line -- documented broken in
    // every major engine: https://www.w3.org/TR/thai-gap/
    const final: Segment[] = [];
    for (const seg of segments) {
      if (seg.type !== 'text') {
        final.push(seg);
        continue;
      }
      const clusters = toGraphemeClusters(seg.value);
      let buffer: string[] = [];
      for (const cluster of clusters) {
        if (cluster === 'ๆ' && buffer.length > 0) {
          const lastCluster = buffer.pop()!;
          if (buffer.length) final.push({ type: 'text', value: buffer.join('') });
          final.push({ type: 'nowrap', value: lastCluster + 'ๆ' });
          buffer = [];
        } else {
          buffer.push(cluster);
        }
      }
      if (buffer.length) final.push({ type: 'text', value: buffer.join('') });
    }
    return final;
  }

  function segmentsToHtml(segments: Segment[]): string {
    return segments
      .map((seg) => {
        const escaped = escapeHtml(seg.value);
        return seg.type === 'nowrap' ? `<span style="white-space:nowrap">${escaped}</span>` : escaped;
      })
      .join('');
  }

  // Exactly what scripts/apply-thai-word-joins.mjs does at build time,
  // reading the same src/data/thai-word-joins.json -- run here live so the
  // "fixed" tab can react to whatever the reader types, not just the
  // default paragraph.
  function applyCuratedList(text: string): string {
    return segmentsToHtml(segmentThaiText(text, sortedApprovedWords));
  }

  const CAPTIONS_TH: Record<string, string> = {
    broken:
      'จำลอง: ถ้าไม่มีข้อมูลขอบเขตคำเลย ระบบจะตัดบรรทัดตรงไหนก็ได้ที่พอดีขอบจอ แม้อยู่กลางตัวอักษร (จำลองด้วย word-break: break-all เพื่อให้เห็นผลในทุกเบราว์เซอร์ -- ไม่ใช่การจำลองบั๊กจริงของ WebKit เป๊ะๆ ซึ่งเกิดจาก word-break: keep-all)',
    native:
      'นี่คือสิ่งที่เบราว์เซอร์ของคุณตัดคำเองตามค่าเริ่มต้น (หลังลบ word-break: keep-all แล้ว) -- ยังมีคำจริงๆ ที่ dictionary ของ browser เองก็ตัดผิด เกิดขึ้นจริงในทุกเบราว์เซอร์ ไม่ใช่แค่ WebKit',
    fixed:
      `หลังห่อคำในรายการที่ตรวจสอบด้วยมือแล้ว ${approvedThaiWords.length} คำ (บวกกฎ Maiyamok ที่ ๆ ต้องไม่ขึ้นต้นบรรทัด) ด้วย white-space:nowrap span -- นี่คือ mechanism เดียวกับที่ postbuild script ใช้จริงบนเว็บนี้ (อ่านจากไฟล์เดียวกัน src/data/thai-word-joins.json) ลองพิมพ์ข้อความของตัวเองด้านบนดูได้เลย`,
    fullLoading: 'กำลังโหลด nlpo3-newmm-typescript (~314KB, ครั้งเดียว)...',
    fullError: 'โหลดไม่สำเร็จ (อาจเป็นปัญหาเครือข่ายชั่วคราว) -- กดแท็บนี้อีกครั้งเพื่อลองใหม่',
    full:
      'ผลลัพธ์จากการรัน nlpo3-newmm-typescript เต็มรูปแบบสด ๆ ในเบราว์เซอร์ของคุณตอนนี้ (ไม่ใช่แค่รายการคำที่คัดแล้ว) สังเกตว่าบางทีมันรวมคำเป็นวลียาวเกินจำเป็น (เช่น "เพื่อให้") ซึ่งเป็นเหตุผลที่เว็บนี้เลือกไม่ใช้ผลลัพธ์นี้ตรงๆ',
  };

  const CAPTIONS_EN: Record<string, string> = {
    broken:
      "Simulated: with zero word-boundary information, a renderer can break a line anywhere it happens to fit -- even mid-character. (Forced here with word-break: break-all so it's visible in every browser -- this is NOT a literal replay of the real WebKit bug, which came from word-break: keep-all.)",
    native:
      "This is what your own browser does with its default Thai segmentation (after removing word-break: keep-all) -- there are still real words the browser's own dictionary splits wrong. Happens in every browser, not just WebKit.",
    fixed:
      `After wrapping the ${approvedThaiWords.length}-word hand-reviewed list (plus every Maiyamok ๆ) in white-space:nowrap spans -- this is the exact same mechanism the postbuild script uses in production (reads the same src/data/thai-word-joins.json). Try typing your own text above.`,
    fullLoading: 'Loading nlpo3-newmm-typescript (~314KB, one-time)...',
    fullError: 'Failed to load (possibly a transient network issue) -- click this tab again to retry.',
    full:
      "Live output from running the full nlpo3-newmm-typescript tokenizer in your browser right now (not the curated list). Notice it sometimes lumps whole phrases together (e.g. \"เพื่อให้\") more than necessary -- that's exactly why this site doesn't use this output directly.",
  };

  demos.forEach((container) => {
    const tabs = Array.from(container.querySelectorAll<HTMLButtonElement>('.thai-demo-tab'));
    const textEl = container.querySelector<HTMLElement>('.thai-demo-text');
    const captionEl = container.querySelector<HTMLElement>('[data-caption]');
    const inputEl = container.querySelector<HTMLTextAreaElement>('.thai-demo-input');
    if (!textEl || !captionEl || !inputEl) return;

    const langAttr = container.closest<HTMLElement>('[lang]')?.getAttribute('lang');
    const CAPTIONS = langAttr === 'en' ? CAPTIONS_EN : CAPTIONS_TH;

    let currentMode = 'broken';
    let tokenizerPromise: Promise<any> | null = null;
    function loadTokenizer() {
      if (!tokenizerPromise) {
        // nlpo3-newmm-typescript's own `new NewmmTokenizer()` constructor
        // calls fs.readFileSync() to load its bundled dictionary -- that
        // works in Node (which is all the package was designed/tested for)
        // but throws in a real browser, since there's no filesystem. Bypass
        // it: fetch the same dictionary file as a plain static asset and
        // build the tokenizer via the from-word-list constructor instead,
        // which never touches fs.
        tokenizerPromise = Promise.all([
          import('nlpo3-newmm-typescript'),
          fetch('/data/nlpo3-words-th.txt').then((r) => r.text()),
        ]).then(([mod, text]) => {
          const words = text.split('\n').map((w) => w.trim()).filter(Boolean);
          return mod.NewmmTokenizer.fromWordList(words);
        });
      }
      return tokenizerPromise;
    }

    async function render() {
      const requestedMode = currentMode;
      const source = inputEl!.value;

      tabs.forEach((tab) => {
        const active = tab.dataset.mode === requestedMode;
        tab.classList.toggle('active', active);
        tab.setAttribute('aria-selected', String(active));
      });

      if (requestedMode === 'broken') {
        textEl!.style.wordBreak = 'break-all';
        textEl!.style.overflowWrap = 'normal';
        textEl!.textContent = source;
        captionEl!.textContent = CAPTIONS.broken;
      } else if (requestedMode === 'fixed') {
        textEl!.style.wordBreak = '';
        textEl!.style.overflowWrap = '';
        textEl!.innerHTML = applyCuratedList(source);
        captionEl!.textContent = CAPTIONS.fixed;
      } else if (requestedMode === 'full') {
        textEl!.style.wordBreak = '';
        textEl!.style.overflowWrap = '';
        textEl!.textContent = source;
        captionEl!.textContent = CAPTIONS.fullLoading;
        const t0 = performance.now();
        try {
          const tokenizer = await loadTokenizer();
          const tokens: string[] = tokenizer.segment(source, true);
          const t1 = performance.now();
          // guard against a stale write if the reader switched tabs/text mid-load
          if (currentMode === requestedMode) {
            // Same white-space:nowrap approach as applyCuratedList -- wrap
            // every token boundary so nothing breaks inside a token, without
            // the WORD JOINER side effect described above.
            textEl!.innerHTML = tokens.map((t) => `<span style="white-space:nowrap">${escapeHtml(t)}</span>`).join('');
            captionEl!.textContent = `${CAPTIONS.full} (${Math.round(t1 - t0)}ms)`;
          }
        } catch (err) {
          // Seen in local dev when Vite's dependency pre-bundle cache goes
          // stale after this dynamic import is added mid-session (a 504
          // "Outdated Optimize Dep") -- fixed by restarting `astro dev`, but
          // readers should never see an infinite "loading" state either way.
          if (currentMode === requestedMode) {
            tokenizerPromise = null; // allow a retry on next click instead of replaying the same failure
            captionEl!.textContent = CAPTIONS.fullError;
          }
          console.error('Thai demo: failed to load/run nlpo3-newmm-typescript', err);
        }
      } else {
        textEl!.style.wordBreak = '';
        textEl!.style.overflowWrap = '';
        textEl!.textContent = source;
        captionEl!.textContent = CAPTIONS.native;
      }
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        currentMode = tab.dataset.mode || 'native';
        render();
      });
    });

    let debounceTimer: number;
    inputEl.addEventListener('input', () => {
      window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(render, 300);
    });

    render();
  });
</script>

