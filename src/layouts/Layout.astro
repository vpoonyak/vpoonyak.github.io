---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  isHome?: boolean;
}

const {
  title = "Vitchakorn Poonyakanok | Physician, Clinical AI & Public Health Data",
  description = "Vitchakorn (Blue) Poonyakanok is a physician, travel medicine resident, and clinical data analyst building clinical AI, travel medicine tools, and public health data systems.",
  image = "https://vitchakorn.com/pic/og-card.jpg",
  canonicalUrl = "https://vitchakorn.com/",
  isHome = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Vitchakorn Poonyakanok">
  <meta name="keywords" content="Vitchakorn Poonyakanok, Blue Poonyakanok, physician, clinical AI, travel medicine, public health data, medical informatics, clinical data analyst, health care analytics">
  <meta name="google-site-verification" content="ggpyNV2PPWEqnqU-NbSOp23tEzoVmyP40YXX4Mz0ves">
  <link rel="canonical" href={canonicalUrl}>
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={isHome ? "website" : "article"}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:site_name" content="Vitchakorn Poonyakanok">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={image}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="1200">
  <meta property="og:image:alt" content="Vitchakorn Poonyakanok — physician bridging travel medicine, public health, data analysis, and AI engineering into intelligent health systems.">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={canonicalUrl}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={image}>
  <meta name="twitter:image:alt" content="Vitchakorn Poonyakanok — physician bridging travel medicine, public health, data analysis, and AI engineering into intelligent health systems.">
  
  {isHome && (
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://vitchakorn.com/#website",
          "url": "https://vitchakorn.com/",
          "name": "Vitchakorn Poonyakanok",
          "description": "Portfolio of Vitchakorn Poonyakanok, a physician and clinical data analyst working on clinical AI, travel medicine tools, and public health data systems.",
          "inLanguage": "en"
        },
        {
          "@type": "Person",
          "@id": "https://vitchakorn.com/#person",
          "name": "Vitchakorn Poonyakanok",
          "alternateName": "Blue Poonyakanok",
          "url": "https://vitchakorn.com/",
          "image": "https://vitchakorn.com/pic/vitchakorn.png",
          "email": "mailto:vk.poonyakanok@gmail.com",
          "jobTitle": [
            "Physician",
            "Travel Medicine Resident",
            "Clinical Data Analyst"
          ],
          "homeLocation": {
            "@type": "Place",
            "name": "Bangkok, Thailand"
          },
          "alumniOf": [
            {
              "@type": "CollegeOrUniversity",
              "name": "Mahidol University"
            },
            {
              "@type": "CollegeOrUniversity",
              "name": "Chulalongkorn University"
            }
          ],
          "knowsAbout": [
            "Clinical AI",
            "Travel Medicine",
            "Public Health Data",
            "Medical Informatics",
            "Clinical Decision Support",
            "Health Care Analytics"
          ],
          "sameAs": [
            "https://www.linkedin.com/in/vitchakorn",
            "https://scholar.google.com/citations?user=r9uxNqQAAAAJ&hl=en",
            "https://www.researchgate.net/profile/Vitchakorn-Poonyakanok",
            "https://orcid.org/0009-0007-9945-0376",
            "https://github.com/vpoonyak",
            "https://huggingface.co/vpoonyak",
            "https://g.dev/vitchakorn",
            "https://www.kaggle.com/vitchakorn",
            "https://public.tableau.com/app/profile/vitchakorn.poonyakanok"
          ]
        }
      ]
    }
    </script>
  )}

  <link rel="icon" href="/favicon/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon/favicon-32x32.png" sizes="32x32" type="image/png">
  <link rel="icon" href="/favicon/favicon-16x16.png" sizes="16x16" type="image/png">
  <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png">
  <noscript><style>.fade-in{opacity:1;transform:none;}</style></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Critical inline script to prevent theme flash (Finding 3 resolved) -->
  <script is:inline>
    (function() {
      const savedTheme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', savedTheme);
    })();
  </script>
</head>
<body data-theme="dark">
  <slot />

  <!-- Global Client Side scripts -->
  <script>
    // Theme toggle runtime event registration
    const htmlEl = document.documentElement;
    const bodyEl = document.body;
    const themeToggle = document.getElementById('themeToggle');

    // Make sure body attribute matches document element immediately
    const currentTheme = htmlEl.getAttribute('data-theme') || 'dark';
    bodyEl.setAttribute('data-theme', currentTheme);

    if (themeToggle) {
      themeToggle.addEventListener('click', function() {
        const current = htmlEl.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        htmlEl.setAttribute('data-theme', next);
        bodyEl.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    }
  </script>
</body>
</html>
