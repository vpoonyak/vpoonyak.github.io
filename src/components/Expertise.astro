---
// Astro Component
---

<section class="section" id="expertise" hidden>
    <div class="container-grid">
      <div class="section-header fade-in">
        <span class="t-section-number">03</span>
        <div>
          <h2 class="t-label section-title">Expertise</h2>
          <div class="section-header-rule"></div>
        </div>
      </div>
      <div class="expertise-grid fade-in delay-1">
        <div class="expertise-card">
          <div class="expertise-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="expertise-title">Travel Medicine</h3>
          <ul class="expertise-list">
            <li>Pre-travel health risk assessment &amp; counseling</li>
            <li>Immunization strategy &amp; vaccination scheduling</li>
            <li>Tropical &amp; emerging infectious disease diagnosis</li>
            <li>Malaria prophylaxis &amp; post-travel fever evaluation</li>
            <li>Altitude illness prevention &amp; management</li>
            <li>Epidemiological surveillance &amp; outbreak response</li>
          </ul>
        </div>
        <div class="expertise-card">
          <div class="expertise-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>
          </div>
          <h3 class="expertise-title">Health Informatics</h3>
          <ul class="expertise-list">
            <li>Clinical decision support system design</li>
            <li>National vaccine registry architecture</li>
            <li>Machine learning for clinical risk stratification</li>
            <li>Health data interoperability</li>
            <li>Digital disease surveillance &amp; epidemic intelligence</li>
            <li>NLP for clinical text mining &amp; data extraction</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
