<section class="section section-alt-bg" id="experience">
    <div class="container-grid">
      <div class="section-header fade-in">
        <span class="t-section-number">02</span>
        <div>
          <h2 class="t-label section-title">Experience</h2>
          <div class="section-header-rule"></div>
        </div>
      </div>
      <div class="exp-grid">
        <div class="fade-in delay-1">
          <div class="exp-category-label">Clinical &amp; Research</div>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-year">2024 — Present <span class="timeline-chip">Current</span></div>
              <div class="timeline-header">
                  <div class="timeline-logo-wrap">
                      <img src="experience/ipm.png" alt="IPM" class="timeline-logo">
                      <img src="experience/moph.png" alt="MOPH" class="timeline-logo">
                  </div>
                  <div>
                      <div class="timeline-role">Travel Medicine Resident</div>
                      <div class="timeline-org">Institute of Preventive Medicine, DDC, MOPH</div>
                      <div class="timeline-location">Nonthaburi, Thailand</div>
