---
// Astro Component
---

<section class="section section-alt-bg" id="contact">
    <div class="container-grid">
      <div class="section-header fade-in">
        <span class="t-section-number">07</span>
        <div>
          <h2 class="t-label section-title">Contact</h2>
          <div class="section-header-rule"></div>
        </div>
      </div>
      <div class="contact-grid">
        <div class="fade-in delay-1">
          <p class="contact-cta">Open to new ideas and collaborations in <span class="accent-word">health data initiatives</span>, medical informatics, travel medicine, and public health research.</p>
          <p class="t-body-large font-mono" style="font-size:0.8125rem;color:var(--text-tertiary);margin-top:0.75rem;">Actively seeking a Summer 2027 health care analytics internship in the United States — open to any state.</p>
          <div style="margin-top: 2rem;">
            <span class="t-label" style="display:block;margin-bottom:0.5rem;">Direct Email</span>
            <a href="mailto:vk.poonyakanok@gmail.com" class="about-contact-email" style="font-size: 1rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              vk.poonyakanok@gmail.com
            </a>
            <p class="contact-formal-review">For formal review: <a href="/cv.pdf" target="_blank" rel="noopener noreferrer">CV</a> · <a href="/resume.pdf" target="_blank" rel="noopener noreferrer">Resume</a></p>
          </div>
        </div>
        <div class="fade-in delay-2">
          <form action="https://formspree.io/f/myklppap" method="POST" class="contact-form">
            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your full name" class="form-input">
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="_replyto" required placeholder="Your email address" class="form-input">
            </div>
            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" required placeholder="How can I help you?" class="form-textarea"></textarea>
            </div>
            <button type="submit" class="submit-btn">
              <span>Send Message</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
