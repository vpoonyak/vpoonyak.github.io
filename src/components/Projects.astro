---
// Astro Component
---

<section class="section" id="projects">
    <div class="container-grid">
      <div class="section-header fade-in">
        <span class="t-section-number">03</span>
        <div>
          <h2 class="t-label section-title">Top Projects</h2>
          <div class="section-header-rule"></div>
        </div>
      </div>
      <div class="featured-project-carousel fade-in delay-1" id="projectCarousel" aria-label="Featured projects">
        <div class="featured-project-header">
          <span class="t-label">Featured Work</span>
          <div class="featured-project-controls">
            <button type="button" class="carousel-btn" id="projectPrev" aria-label="Previous featured project">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button type="button" class="carousel-btn" id="projectNext" aria-label="Next featured project">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>
        <article class="featured-project-slide active" aria-hidden="false">
          <a href="project/ddschatbot/" target="_blank" class="featured-project-media-link" rel="noopener noreferrer" aria-hidden="true" tabindex="-1">
