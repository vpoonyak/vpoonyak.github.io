        <div class="carousel-dots" aria-label="Featured project selector">
          <button type="button" class="carousel-dot" data-project-slide="0" aria-label="Show DDS Chatbot" aria-current="true"></button>
          <button type="button" class="carousel-dot" data-project-slide="1" aria-label="Show Altitude Itinerary Analyzer" aria-current="false"></button>
          <button type="button" class="carousel-dot" data-project-slide="2" aria-label="Show Yellow Fever Vaccine and Malaria Prevention Dashboard" aria-current="false"></button>
          <button type="button" class="carousel-dot" data-project-slide="3" aria-label="Show Thai HospSearch" aria-current="false"></button>
          <button type="button" class="carousel-dot" data-project-slide="4" aria-label="Show Hajj Menstrual Delay Planner" aria-current="false"></button>
          <button type="button" class="carousel-dot" data-project-slide="5" aria-label="Show PM2.5 and Mental Health Dynamics" aria-current="false"></button>
          <button type="button" class="carousel-dot" data-project-slide="6" aria-label="Show Cirrhosis Survival Prediction" aria-current="false"></button>
          <button type="button" class="carousel-dot" data-project-slide="7" aria-label="Show Thai Numeral Converter" aria-current="false"></button>
          <button type="button" class="carousel-dot" data-project-slide="8" aria-label="Show BNK/CGM48 4th General Election Predictive Analysis" aria-current="false"></button>
        </div>
