      <div class="cert-archive-link-row">
        <a href="project/" target="_blank" rel="noopener noreferrer" class="nav-action-link">View Full Project Archive</a>
      </div>
    </div>
  </section>

<script>
    // ── Featured Project Carousel ──
    const projectCarousel = document.getElementById('projectCarousel');

    if (projectCarousel) {
      const projectSlides = projectCarousel.querySelectorAll('.featured-project-slide');
      const projectDots = projectCarousel.querySelectorAll('.carousel-dot');
      const projectDesktopDots = projectCarousel.querySelector(':scope > .carousel-dots');
      const projectPrev = document.getElementById('projectPrev');
      const projectNext = document.getElementById('projectNext');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let activeProjectSlide = 0;
      let projectTimer = null;
      let projectCarouselInView = false;
      let projectTouchStartX = 0;
      let projectTouchStartY = 0;
      let suppressProjectClick = false;
      const projectMobileNav = document.createElement('div');
      const mobileDots = document.createElement('div');
      projectMobileNav.className = 'featured-project-mobile-nav';
      projectMobileNav.setAttribute('aria-label', 'Featured project mobile controls');
      mobileDots.className = 'carousel-dots';

      projectMobileNav.innerHTML = `
        <button type="button" class="carousel-btn" data-project-action="prev" aria-label="Previous featured project">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
      `;

      projectDots.forEach(function(dot) {
        const mobileDot = dot.cloneNode(true);
        mobileDots.appendChild(mobileDot);
      });

      projectMobileNav.appendChild(mobileDots);
      projectMobileNav.insertAdjacentHTML('beforeend', `
        <button type="button" class="carousel-btn" data-project-action="next" aria-label="Next featured project">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      `);

      function updateProjectDots() {
        projectCarousel.querySelectorAll('.carousel-dot').forEach(function(dot) {
          dot.setAttribute('aria-current', parseInt(dot.getAttribute('data-project-slide'), 10) === activeProjectSlide ? 'true' : 'false');
        });
      }

      function placeProjectMobileNav() {
        const activeSlide = projectSlides[activeProjectSlide];
        if (!activeSlide) return;

        const mediaLink = activeSlide.querySelector('.featured-project-media-link');
        if (mediaLink && projectMobileNav.parentNode !== activeSlide) {
          mediaLink.insertAdjacentElement('afterend', projectMobileNav);
        }
      }

      function showProjectSlide(index, direction) {
        const previousProjectSlide = activeProjectSlide;
        activeProjectSlide = (index + projectSlides.length) % projectSlides.length;
        const slideDirection = direction || (activeProjectSlide >= previousProjectSlide ? 'next' : 'prev');

        projectSlides.forEach(function(slide, slideIndex) {
          const isActive = slideIndex === activeProjectSlide;
          slide.classList.toggle('active', isActive);
          slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
          slide.classList.remove('slide-from-next', 'slide-from-prev');

          if (isActive && activeProjectSlide !== previousProjectSlide && !reduceMotion) {
            slide.classList.add(slideDirection === 'prev' ? 'slide-from-prev' : 'slide-from-next');
            window.setTimeout(function() {
              slide.classList.remove('slide-from-next', 'slide-from-prev');
            }, 320);
          }
        });

        updateProjectDots();
        placeProjectMobileNav();
      }

      function nextProjectSlide() {
        showProjectSlide(activeProjectSlide + 1, 'next');
      }

      function previousProjectSlide() {
        showProjectSlide(activeProjectSlide - 1, 'prev');
      }

      function startProjectCarousel() {
        if (reduceMotion || projectTimer || !projectCarouselInView) return;
        projectTimer = window.setInterval(nextProjectSlide, 3500);
      }

      function stopProjectCarousel() {
        if (!projectTimer) return;
        window.clearInterval(projectTimer);
        projectTimer = null;
      }

      if (projectPrev) {
        projectPrev.addEventListener('click', function() {
          stopProjectCarousel();
          previousProjectSlide();
          startProjectCarousel();
        });
      }

      if (projectNext) {
        projectNext.addEventListener('click', function() {
          stopProjectCarousel();
          nextProjectSlide();
          startProjectCarousel();
        });
      }

      projectDots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          stopProjectCarousel();
          showProjectSlide(parseInt(dot.getAttribute('data-project-slide'), 10));
          startProjectCarousel();
        });
      });

      projectCarousel.addEventListener('click', function(event) {
        if (suppressProjectClick) {
          event.preventDefault();
          event.stopPropagation();
          suppressProjectClick = false;
          return;
        }

        const actionButton = event.target.closest('[data-project-action]');
        if (actionButton) {
          event.preventDefault();
          stopProjectCarousel();
          actionButton.getAttribute('data-project-action') === 'prev' ? previousProjectSlide() : nextProjectSlide();
          startProjectCarousel();
          return;
        }

        const dot = event.target.closest('.carousel-dot');
        if (dot && !projectDesktopDots.contains(dot)) {
          event.preventDefault();
          stopProjectCarousel();
          showProjectSlide(parseInt(dot.getAttribute('data-project-slide'), 10));
          startProjectCarousel();
        }
      });

      projectCarousel.addEventListener('touchstart', function(event) {
        if (!window.matchMedia('(max-width: 768px)').matches || event.touches.length !== 1) return;
        projectTouchStartX = event.touches[0].clientX;
        projectTouchStartY = event.touches[0].clientY;
      }, { passive: true });

      projectCarousel.addEventListener('touchend', function(event) {
        if (!window.matchMedia('(max-width: 768px)').matches || !event.changedTouches.length) return;

        const deltaX = event.changedTouches[0].clientX - projectTouchStartX;
        const deltaY = event.changedTouches[0].clientY - projectTouchStartY;

        if (Math.abs(deltaX) > 48 && Math.abs(deltaX) > Math.abs(deltaY) * 1.3) {
          stopProjectCarousel();
          deltaX < 0 ? nextProjectSlide() : previousProjectSlide();
          startProjectCarousel();
          suppressProjectClick = true;
          window.setTimeout(function() {
            suppressProjectClick = false;
          }, 250);
        }
      }, { passive: true });

      projectCarousel.addEventListener('mouseenter', stopProjectCarousel);
      projectCarousel.addEventListener('mouseleave', startProjectCarousel);
      projectCarousel.addEventListener('focusin', stopProjectCarousel);
      projectCarousel.addEventListener('focusout', startProjectCarousel);

      showProjectSlide(0);

      if ('IntersectionObserver' in window) {
        const projectCarouselObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            projectCarouselInView = entry.isIntersecting;

            if (projectCarouselInView) {
              showProjectSlide(0);
              startProjectCarousel();
            } else {
              stopProjectCarousel();
            }
          });
        }, { threshold: 0.35 });

        projectCarouselObserver.observe(projectCarousel);
      } else {
        projectCarouselInView = true;
        startProjectCarousel();
      }
    }

</script>
