---
// Astro Component
---

<section class="hero container-grid" id="top">
    <div class="hero-globe" aria-hidden="true"><canvas id="heroGlobe"></canvas></div>
    <h1 class="hero-name">
      <span class="t-hero name-line"><span class="accent-char">V</span>itchakorn</span>
      <span class="t-hero name-line">Poonyakanok</span>
    </h1>
    <div class="hero-rule"></div>
    <p class="hero-positioning">
      <span class="sr-only">Physician bridging travel medicine, public health, data analysis, and AI engineering into intelligent health systems.</span>
      <span aria-hidden="true">Physician bridging <span class="role-swap" id="roleSwap"><span class="role-word accent-word">travel medicine</span></span> into intelligent health systems.</span>
    </p>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span class="t-label">Specialty</span>
        <span style="font-size:0.875rem;font-weight:500;color:var(--text-primary);">MD, Travel Medicine<br>M.S. Digital &amp; AI Health Systems</span>
      </div>
      <div class="hero-meta-item">
        <span class="t-label">Location</span>
        <span style="font-size:0.875rem;font-weight:500;color:var(--text-primary);">Bangkok, Thailand</span>
      </div>
      <div class="hero-meta-item">
        <span class="t-label">Status</span>
        <span style="font-size:0.875rem;font-weight:500;color:var(--text-primary);display:flex;align-items:center;gap:6px;">
          <span class="status-dot" style="width:5px;height:5px;"></span> Seeking Summer 2027 Internship (USA)
        </span>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <span class="t-label" style="writing-mode:vertical-rl;font-size:0.5625rem;">Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

<script>
    // ── Hero Dot Canvas ──
    // One particle field, four shapes (rikai-style): a spinning world globe
    // with live flight arcs (travel medicine) whose main route flies westward
    // Pittsburgh → Bangkok with the globe rotating in sync; a real
    // hospital-density choropleth of Thailand with a contact-tracing overlay
    // (public health); an epi-curve chart (data analysis); and a neural
    // network (AI engineering). Dots tween between shapes with a
    // collapse-then-expand beat, synced to the hero role swapper via the
    // 'rolechange' event. Land mask: 480x240 equirect, 1 bit/px. Thailand
    // dots: precomputed offline from province polygons + hospital counts,
    // 3 bytes/dot (x, y, intensity tier). The canvas is non-interactive.
    (function () {
      var canvas = document.getElementById('heroGlobe');
      if (!canvas || !canvas.getContext) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;

      var MASK_W = 480, MASK_H = 240;
      var MASK_B64 = '';
      var THAI_B64 = '';

      var maskBin = atob(MASK_B64);
      function isLand(lonDeg, latDeg) {
        var x = Math.min(MASK_W - 1, Math.floor((lonDeg + 180) / 360 * MASK_W));
        var y = Math.min(MASK_H - 1, Math.floor((90 - latDeg) / 180 * MASK_H));
        var i = y * MASK_W + x;
        return (maskBin.charCodeAt(i >> 3) >> (7 - (i & 7))) & 1;
      }

      var isSmallScreen = window.matchMedia('(max-width: 768px)').matches;
      var reduceMotionGlobe = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var DOT_COUNT = isSmallScreen ? 2200 : 4400;

      // ── Dot field ── unit coords in [-1,1], y down; drawn at center + p*R
      var dots = [];
      var guard = 0;
      while (dots.length < DOT_COUNT && guard++ < DOT_COUNT * 500) {
        var lon = Math.random() * 360 - 180;
        var lat = Math.asin(Math.random() * 2 - 1) * 180 / Math.PI;
        if (isLand(lon, lat)) {
          var latR = lat * Math.PI / 180;
          dots.push({
            cosLat: Math.cos(latR),
            sinLat: Math.sin(latR),
            lon: lon * Math.PI / 180,
            jitter: 0.75 + Math.random() * 0.5,
            // skewed long-tail: most dots stay dim, a minority spike bright —
            // reads as scattered city lights rather than an even sprinkle
            glow: 0.32 + Math.pow(Math.random(), 2.4) * 1.55,
            x: 0, y: 0, a: 0, size: 1,
            sx: 0, sy: 0, sa: 0,
            wx: 0, wy: 0, ex: 0, ey: 0,
            tx: 0, ty: 0, ta: 0, tsize: 1, tphase: 0, tgroup: 0, tpath: -1,
            delay: 0
          });
        }
      }

      var TILT = -0.3;
      var cosT = Math.cos(TILT), sinT = Math.sin(TILT);

      // ── Shapes ── target lists: {x, y, a, size, phase, group, path}
      function padShape(targets) {
        // densify glyphs up to DOT_COUNT by echoing targets with soft offsets
        var base = targets.length;
        if (!base) return targets;
        while (targets.length < DOT_COUNT) {
          var src = targets[Math.floor(Math.random() * base)];
          targets.push({
            x: src.x + (Math.random() - 0.5) * 0.016,
            y: src.y + (Math.random() - 0.5) * 0.016,
            a: src.a * 0.55, size: src.size * 0.8,
            phase: src.phase, group: src.group, path: -1
          });
        }
        return targets.slice(0, DOT_COUNT);
      }

      function T(x, y, a, size, phase, group, path) {
        return { x: x, y: y, a: a, size: size || 1, phase: phase || 0, group: group || 0, path: path === undefined ? -1 : path };
      }

      // Contact-tracing overlay nodes chosen from the decoded Thailand dots
      var traceNodes = [];
      // Neural-net layout, saved at build time for the roaming signal overlay
      var netLayers = null;

      // Deterministic small PRNG so looped animations vary per cycle but stay
      // stable within one
      function mulberry(seed) {
        return function () {
          seed |= 0; seed = seed + 0x6D2B79F5 | 0;
          var z = Math.imul(seed ^ seed >>> 15, 1 | seed);
          z = z + Math.imul(z ^ z >>> 7, 61 | z) ^ z;
          return ((z ^ z >>> 14) >>> 0) / 4294967296;
        };
      }

      // Seasonal surveillance series: ~1.5 seasons of fixed history (raw
      // observations live in the dot field), the current season streams in as
      // an overlay, and a seasonal-naive forecast projects the next rise.
      // stepMs is paced so the stream + forecast keep advancing for the
      // entire ~6s 'data' role window (see ROLE_PERIOD in the Hero Role
      // Cycle IIFE) instead of finishing early and sitting frozen.
      var CH = { x0: -0.74, x1: 0.76, y0: 0.58, h: 1.05, hist: 36, stream: 24, period: 24, fore: 8, stepMs: 225 };
      CH.total = CH.hist + CH.stream;
      var AMP_A = 0.68, AMP_B = 0.95;

      // von Mises-like seasonal bump, one peak per period
      function seasonShape(phase) {
        return Math.exp(3.0 * (Math.cos((phase - 0.58) * 6.2832) - 1));
      }

      function seasonValue(i, amp, rnd) {
        return Math.max(0.02, 0.05 + amp * seasonShape((i % CH.period) / CH.period) + (rnd() - 0.5) * 0.09);
      }

      // fixed-seed history so the dot cloud and the overlay line always agree
      function historySeries() {
        var rnd = mulberry(7);
        var vals = [];
        for (var i = 0; i < CH.hist; i++) {
          vals.push(seasonValue(i, i < CH.period ? AMP_A : AMP_B, rnd));
        }
        return vals;
      }

      function buildThailand() {
        var bin = atob(THAI_B64);
        var targets = [];
        for (var i = 0; i + 2 < bin.length; i += 3) {
          var x = (bin.charCodeAt(i) / 127.5 - 1) * 0.92;
          var y = (bin.charCodeAt(i + 1) / 127.5 - 1) * 0.92;
          var tier = bin.charCodeAt(i + 2);
          targets.push(T(x, y, 0.34 + tier * 0.2, 0.85 + tier * 0.18, tier));
        }
        // trace network: index case at the dot nearest Bangkok, then a dozen
        // contacts spread across the country, each linked to its nearest
        // already-infected predecessor
        var bkx = -0.11, bky = -0.082;
        var best = 0, bestD = 1e9, k, d2;
        for (k = 0; k < targets.length; k++) {
          d2 = (targets[k].x - bkx) * (targets[k].x - bkx) + (targets[k].y - bky) * (targets[k].y - bky);
          if (d2 < bestD) { bestD = d2; best = k; }
        }
        var picked = [targets[best]];
        for (k = 1; k <= 12; k++) {
          var cand = targets[(k * 107) % targets.length];
          picked.push(cand);
        }
        picked.sort(function (a, b) {
          return ((a.x - bkx) * (a.x - bkx) + (a.y - bky) * (a.y - bky)) - ((b.x - bkx) * (b.x - bkx) + (b.y - bky) * (b.y - bky));
        });
        traceNodes = picked.map(function (p, idx) {
          return { x: p.x, y: p.y, parent: 0, act: 900 + idx * 380 };
        });
        for (k = 1; k < traceNodes.length; k++) {
          var bp = 0, bd = 1e9;
          for (var m = 0; m < k; m++) {
            d2 = (traceNodes[k].x - traceNodes[m].x) * (traceNodes[k].x - traceNodes[m].x) + (traceNodes[k].y - traceNodes[m].y) * (traceNodes[k].y - traceNodes[m].y);
            if (d2 < bd) { bd = d2; bp = m; }
          }
          traceNodes[k].parent = bp;
        }
        return padShape(targets);
      }

      function buildChart() {
        var targets = [];
        var i, t, x, y;
        // axes
        for (i = 0; i < 55; i++) {
          t = i / 54;
          targets.push(T(-0.78 + t * 1.58, 0.62, 0.5, 1));
        }
        for (i = 0; i < 42; i++) {
          t = i / 41;
          targets.push(T(-0.78, 0.62 - t * 1.28, 0.5, 1));
        }
        // faint horizontal gridlines
        for (var g = 1; g <= 3; g++) {
          for (i = 0; i < 26; i++) {
            targets.push(T(-0.78 + (i / 25) * 1.58, 0.62 - g * 0.32, 0.14, 0.8, 0, 1));
          }
        }
        // season tick marks on the x-axis (one per period)
        for (var s = 0; s < 3; s++) {
          var tx = CH.x0 + (s * CH.period / (CH.total - 1 + CH.fore)) * (CH.x1 - CH.x0);
          for (i = 0; i < 4; i++) {
            targets.push(T(tx, 0.645 + i * 0.018, 0.45, 0.9));
          }
        }
        // raw historical observations — the faint cloud the rolling average
        // smooths; live season + forecast are drawn as an overlay
        var hist = historySeries();
        var rnd = mulberry(99);
        for (i = 0; i < CH.hist; i++) {
          x = CH.x0 + (i / (CH.total - 1 + CH.fore)) * (CH.x1 - CH.x0);
          for (var rep = 0; rep < 2; rep++) {
            y = CH.y0 - hist[i] * CH.h + (rnd() - 0.5) * 0.055;
            targets.push(T(x + (rnd() - 0.5) * 0.014, y, 0.3, 0.9, i / CH.total, 3));
          }
        }
        return padShape(targets);
      }

      function buildNetwork() {
        var targets = [];
        var layers = [
          { x: -0.6, n: 5 },
          { x: 0.05, n: 7 },
          { x: 0.68, n: 1 }
        ];
        var nodes = [];
        layers.forEach(function (L) {
          var col = [];
          for (var k = 0; k < L.n; k++) {
            var y = L.n === 1 ? 0 : -0.66 + (k / (L.n - 1)) * 1.32;
            col.push({ x: L.x, y: y });
          }
          nodes.push(col);
        });
        netLayers = nodes; // saved for the roaming signal overlay
        function edge(p, q) {
          var steps = 9;
          for (var s = 1; s < steps; s++) {
            var t = s / steps;
            targets.push(T(p.x + (q.x - p.x) * t, p.y + (q.y - p.y) * t, 0.16, 0.85, 0, 4));
          }
        }
        nodes[0].forEach(function (p) { nodes[1].forEach(function (q) { edge(p, q); }); });
        nodes[1].forEach(function (p) { nodes[2].forEach(function (q) { edge(p, q); }); });
        nodes.forEach(function (col, li) {
          col.forEach(function (p) {
            var r = li === 2 ? 0.085 : 0.06;
            var count = li === 2 ? 46 : 26;
            for (var k = 0; k < count; k++) {
              var ang = Math.random() * Math.PI * 2;
              var rr = Math.sqrt(Math.random()) * r;
              targets.push(T(p.x + Math.cos(ang) * rr, p.y + Math.sin(ang) * rr, 0.55 + Math.random() * 0.3, 1.05, 0, 5));
            }
          });
        });
        return padShape(targets);
      }

      var SHAPES = {};
      function getShape(name) {
        if (!SHAPES[name]) {
          SHAPES[name] = name === 'thailand' ? buildThailand()
            : name === 'chart' ? buildChart()
            : buildNetwork();
        }
        return SHAPES[name];
      }

      // ── Flights ──
      function sphereVec(latDeg, lonDeg) {
        var la = latDeg * Math.PI / 180, lo = lonDeg * Math.PI / 180;
        return [Math.cos(la) * Math.sin(lo), Math.sin(la), Math.cos(la) * Math.cos(lo)];
      }

      // Main route: Pittsburgh → Bangkok, flown westward across the Pacific
      // (not the great circle — the story is the journey west). Slight
      // altitude bump lifts the arc off the surface.
      var PIT = { lat: 40.44, lon: -80.0 };
      var BKK = { lat: 13.75, lon: 100.5 };
      var LON_SPAN = 179.5; // degrees west from PIT to BKK
      var ROUTE_N = 110;
      var route = (function () {
        var pts = [];
        for (var i = 0; i <= ROUTE_N; i++) {
          var t = i / ROUTE_N;
          var lonD = PIT.lon - LON_SPAN * t;
          var latD = PIT.lat + (BKK.lat - PIT.lat) * t + 13 * Math.sin(Math.PI * t);
          var v = sphereVec(latD, lonD);
          pts.push({ v: v, alt: 1 + 0.07 * Math.sin(Math.PI * t) });
        }
        return pts;
      })();

      // Ambient world flights (the "connected world" layer)
      var CITIES = {
        nyc: [40.7, -74.0], la: [34.0, -118.2], lon: [51.5, -0.1],
        par: [48.9, 2.4], fra: [50.1, 8.7], dxb: [25.3, 55.3],
        del: [28.6, 77.2], sin: [1.35, 103.8], tyo: [35.7, 139.7],
        sel: [37.6, 127.0], syd: [-33.9, 151.2], nbo: [-1.3, 36.8],
        gru: [-23.6, -46.6], ist: [41.0, 29.0], bkk: [13.75, 100.5]
      };
      var AMBIENT_PAIRS = [
        ['nyc', 'lon'], ['lon', 'dxb'], ['dxb', 'sin'], ['sin', 'tyo'],
        ['tyo', 'la'], ['la', 'nyc'], ['par', 'nbo'], ['fra', 'ist'],
        ['del', 'bkk'], ['bkk', 'syd'], ['gru', 'par'], ['sel', 'sin']
      ];
      var AMB_N = 40;
      var ambient = AMBIENT_PAIRS.map(function (pair, idx) {
        var a = sphereVec(CITIES[pair[0]][0], CITIES[pair[0]][1]);
        var b = sphereVec(CITIES[pair[1]][0], CITIES[pair[1]][1]);
        var dot = a[0] * b[0] + a[1] * b[1] + a[2] * b[2];
        var om = Math.acos(Math.max(-1, Math.min(1, dot)));
        var pts = [];
        for (var i = 0; i <= AMB_N; i++) {
          var t = i / AMB_N;
          var k1 = Math.sin((1 - t) * om) / Math.sin(om);
          var k2 = Math.sin(t * om) / Math.sin(om);
          pts.push({
            v: [a[0] * k1 + b[0] * k2, a[1] * k1 + b[1] * k2, a[2] * k1 + b[2] * k2],
            alt: 1 + 0.06 * Math.sin(Math.PI * t)
          });
        }
        // normalize slerp result back onto the sphere
        pts.forEach(function (p) {
          var n = Math.sqrt(p.v[0] * p.v[0] + p.v[1] * p.v[1] + p.v[2] * p.v[2]);
          p.v[0] /= n; p.v[1] /= n; p.v[2] /= n;
        });
        return { pts: pts, period: 2600 + (idx % 5) * 640, phase: idx / AMBIENT_PAIRS.length };
      });

      // ── Colors / sizing ──
      var accentRGB = '47, 129, 247';
      function refreshGlobeColors() {
        var v = getComputedStyle(htmlEl).getPropertyValue('--accent-rgb').trim();
        if (v) accentRGB = v;
      }
      refreshGlobeColors();
      new MutationObserver(refreshGlobeColors).observe(htmlEl, { attributes: true, attributeFilter: ['data-theme'] });

      var dpr = 1, cw = 0, ch = 0;
      function resizeGlobe() {
        var rect = canvas.parentElement.getBoundingClientRect();
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        var w = Math.max(1, Math.round(rect.width * dpr));
        var h = Math.max(1, Math.round(rect.height * dpr));
        if (w !== cw || h !== ch) {
          cw = w; ch = h;
          canvas.width = cw;
          canvas.height = ch;
          drawFrame(lastFrameT);
        }
      }

      // ── State machine ──
      // mode: 'globe' (sphere math drives dots), 'tween' (collapse→expand to a
      // static shape), 'toglobe' (collapse beat, then chase the spinning
      // sphere), 'shape' (static glyph with per-role modulation)
      var mode = 'globe';
      var activeRole = 'travel';
      var roleStartT = 0, rolePending = true;
      // All timeline math uses performance.now() sampled once per tick — a
      // single clock shared with the role swapper's setInterval. rAF
      // timestamps are NOT used: they can lag performance.now() (notably
      // under virtualized time), which would strand dots mid-tween.
      var tweenStart = 0, tweenPending = false, tweenEnd = 'shape', tweenZoom = false;
      var TWEEN_A = 380, TWEEN_B = 640, TWEEN_STAGGER = 250;
      var CHASE_MS = 950;

      // Travel choreography: globe forms on Pittsburgh, the flight departs,
      // the globe spins westward with the flight, lands on Bangkok and holds.
      var FLIGHT_DELAY = 1500, FLIGHT_DUR = 3200;
      var flightP = 0; // eased progress 0..1
      var phi = (80 + 0) * Math.PI / 180; // Pittsburgh centered

      function smoothstep(t) { return t * t * (3 - 2 * t); }

      function travelClock(now) {
        if (reduceMotionGlobe) { flightP = 1; }
        else {
          var raw = (now - roleStartT - FLIGHT_DELAY) / FLIGHT_DUR;
          flightP = smoothstep(Math.max(0, Math.min(1, raw)));
        }
        phi = (80 + LON_SPAN * flightP) * Math.PI / 180;
      }

      function easeInQuad(t) { return t * t; }
      function easeOutBack(t) {
        var c = 1.35;
        var u = t - 1;
        return 1 + (c + 1) * u * u * u + c * u * u;
      }

      function projectSphere(d, out) {
        var a = d.lon + phi;
        var x0 = d.cosLat * Math.sin(a);
        var z0 = d.cosLat * Math.cos(a);
        var y1 = d.sinLat * cosT + z0 * sinT;
        var z1 = z0 * cosT - d.sinLat * sinT;
        var depth = (z1 + 1) / 2;
        out.x = x0 * 0.92;
        out.y = -y1 * 0.92;
        // per-dot brightness jitter (d.glow) so the sphere reads like
        // scattered city lights rather than a uniform depth gradient
        out.a = (z1 > 0 ? 0.22 + 0.68 * depth : 0.07) * d.glow;
        out.size = (0.55 + 0.75 * depth);
        return out;
      }
      var proj = { x: 0, y: 0, a: 0, size: 1 };

      function beginTween(shapeName, endMode, zoomAnchor, direct) {
        var targets = getShape(shapeName);
        for (var i = 0; i < dots.length; i++) {
          var d = dots[i], t = targets[i];
          d.sx = d.x; d.sy = d.y; d.sa = d.a;
          if (zoomAnchor) {
            // camera dive: the current field rushes radially out past the
            // anchor (fading), and the new shape blooms from that point
            var burst = 2.6 + Math.random() * 0.9;
            d.wx = zoomAnchor.x + (d.x - zoomAnchor.x) * burst;
            d.wy = zoomAnchor.y + (d.y - zoomAnchor.y) * burst;
            d.ex = zoomAnchor.x + (t.x - zoomAnchor.x) * 0.08;
            d.ey = zoomAnchor.y + (t.y - zoomAnchor.y) * 0.08;
          } else if (direct) {
            // location-to-location flight: no collapse beat — each dot
            // accelerates 45% of the way to its target, then settles in
            d.wx = d.x + (t.x - d.x) * 0.45;
            d.wy = d.y + (t.y - d.y) * 0.45;
            d.ex = d.wx; d.ey = d.wy;
          } else {
            d.wx = d.x * 0.1 + (Math.random() - 0.5) * 0.2;
            d.wy = d.y * 0.1 + (Math.random() - 0.5) * 0.2;
            d.ex = d.wx; d.ey = d.wy;
          }
          d.tx = t.x; d.ty = t.y; d.ta = t.a;
          d.tsize = t.size; d.tphase = t.phase; d.tgroup = t.group; d.tpath = t.path;
          d.delay = Math.random() * (zoomAnchor ? 140 : TWEEN_STAGGER) + (d.tgroup === 2 || d.tgroup === 3 ? d.tphase * 500 : 0);
        }
        tweenZoom = !!zoomAnchor;
        tweenPending = true;
        tweenEnd = endMode || 'shape';
        mode = 'tween';
      }

      function beginReturnToGlobe(zoomAnchor) {
        for (var i = 0; i < dots.length; i++) {
          var d = dots[i];
          d.sx = d.x; d.sy = d.y; d.sa = d.a;
          if (zoomAnchor) {
            // camera dive into the anchor: the field rushes radially out
            // past it (fading), then the globe blooms from that point
            var burst = 2.6 + Math.random() * 0.9;
            d.wx = zoomAnchor.x + (d.x - zoomAnchor.x) * burst;
            d.wy = zoomAnchor.y + (d.y - zoomAnchor.y) * burst;
            d.ex = zoomAnchor.x + (Math.random() - 0.5) * 0.12;
            d.ey = zoomAnchor.y + (Math.random() - 0.5) * 0.12;
            d.delay = Math.random() * 140;
          } else {
            d.wx = d.x * 0.1 + (Math.random() - 0.5) * 0.18;
            d.wy = d.y * 0.1 + (Math.random() - 0.5) * 0.18;
            d.delay = Math.random() * TWEEN_STAGGER;
          }
        }
        tweenZoom = !!zoomAnchor;
        tweenPending = true;
        mode = 'toglobe';
      }

      // ── Per-frame update ──
      function updateDots(now, dt) {
        var i, d, k, e;
        if (tweenPending) { tweenStart = now; tweenPending = false; }
        if (rolePending) { roleStartT = now; rolePending = false; }
        if (activeRole === 'travel') travelClock(now);
        if (mode === 'globe') {
          for (i = 0; i < dots.length; i++) {
            d = dots[i];
            projectSphere(d, proj);
            d.x = proj.x; d.y = proj.y; d.a = proj.a; d.size = proj.size;
          }
        } else if (mode === 'tween') {
          var done = true;
          for (i = 0; i < dots.length; i++) {
            d = dots[i];
            e = now - tweenStart - d.delay;
            if (e < 0) { done = false; continue; }
            if (e < TWEEN_A) {
              k = easeInQuad(e / TWEEN_A);
              d.x = d.sx + (d.wx - d.sx) * k;
              d.y = d.sy + (d.wy - d.sy) * k;
              done = false;
            } else if (e < TWEEN_A + TWEEN_B) {
              k = easeOutBack((e - TWEEN_A) / TWEEN_B);
              d.x = d.ex + (d.tx - d.ex) * k;
              d.y = d.ey + (d.ty - d.ey) * k;
              done = false;
            } else {
              d.x = d.tx; d.y = d.ty;
            }
            if (tweenZoom) {
              // fade out on the dive, fade in on the bloom
              if (e < TWEEN_A) {
                d.a = d.sa * (1 - e / TWEEN_A);
              } else {
                k = Math.max(0, Math.min(1, (e - TWEEN_A) / TWEEN_B));
                d.a = d.ta * k;
                d.size = 1 + (d.tsize - 1) * k;
              }
            } else {
              k = Math.max(0, Math.min(1, e / (TWEEN_A + TWEEN_B)));
              d.a = d.sa + (d.ta - d.sa) * k;
              d.size = 1 + (d.tsize - 1) * k;
            }
          }
          if (done) mode = 'shape';
        } else if (mode === 'toglobe') {
          var settled = now - tweenStart > TWEEN_A + CHASE_MS + TWEEN_STAGGER;
          for (i = 0; i < dots.length; i++) {
            d = dots[i];
            e = now - tweenStart - d.delay;
            if (e < 0) continue;
            if (e < TWEEN_A) {
              k = easeInQuad(e / TWEEN_A);
              d.x = d.sx + (d.wx - d.sx) * k;
              d.y = d.sy + (d.wy - d.sy) * k;
              d.a = tweenZoom ? d.sa * (1 - k) : d.sa + (0.1 - d.sa) * k;
            } else if (tweenZoom && e < TWEEN_A + TWEEN_B) {
              // bloom: the globe grows out of the zoom anchor
              projectSphere(d, proj);
              k = easeOutBack((e - TWEEN_A) / TWEEN_B);
              d.x = d.ex + (proj.x - d.ex) * k;
              d.y = d.ey + (proj.y - d.ey) * k;
              k = Math.max(0, Math.min(1, (e - TWEEN_A) / TWEEN_B));
              d.a = proj.a * k;
              d.size = 1 + (proj.size - 1) * k;
            } else {
              projectSphere(d, proj);
              var ease = 1 - Math.pow(0.9, dt / 16.7);
              d.x += (proj.x - d.x) * ease;
              d.y += (proj.y - d.y) * ease;
              d.a += (proj.a - d.a) * ease;
              d.size += (proj.size - d.size) * ease;
            }
          }
          if (settled) mode = 'globe';
        } else { // 'shape' — static glyph, role-specific life
          for (i = 0; i < dots.length; i++) {
            d = dots[i];
            if (activeRole === 'health') {
              d.a = d.ta * (0.82 + 0.18 * Math.sin(now / 700 + d.tgroup * 1.7 + d.tx * 2));
            } else if (activeRole === 'data' && d.tgroup === 2) {
              d.a = d.ta * (0.88 + 0.12 * Math.sin(now / 500 + d.tphase * 9));
            }
          }
        }
      }

      function projectVec(v, alt, out) {
        var sinP = Math.sin(phi), cosP = Math.cos(phi);
        var x0 = v[0] * cosP + v[2] * sinP;
        var z0 = -v[0] * sinP + v[2] * cosP;
        var y1 = v[1] * cosT + z0 * sinT;
        var z1 = z0 * cosT - v[1] * sinT;
        out.x = x0 * 0.92 * alt;
        out.y = -y1 * 0.92 * alt;
        out.z = z1;
        return out;
      }
      var vproj = { x: 0, y: 0, z: 0 };

      function drawFlights(now, cx, cy, R, dotBase) {
        var j, p, t, alpha, sz;
        // ambient network — the world stays connected
        for (var a = 0; a < ambient.length; a++) {
          var arc = ambient[a];
          var head = ((now / arc.period) + arc.phase) % 1;
          for (j = 0; j <= AMB_N; j++) {
            p = arc.pts[j];
            projectVec(p.v, p.alt, vproj);
            if (vproj.z < -0.05) continue;
            t = j / AMB_N;
            var dh = head - t;
            var comet = (dh >= 0 && dh < 0.14) ? 1 - dh / 0.14 : 0;
            alpha = 0.07 + comet * 0.3;
            sz = dotBase * (0.7 + comet * 0.8);
            ctx.fillStyle = 'rgba(' + accentRGB + ',' + alpha.toFixed(3) + ')';
            ctx.fillRect(cx + vproj.x * R - sz, cy + vproj.y * R - sz, sz * 2, sz * 2);
          }
        }
        // main route: departs Pittsburgh, lands Bangkok; trail persists
        for (j = 0; j <= ROUTE_N; j++) {
          t = j / ROUTE_N;
          if (t > flightP) break;
          p = route[j];
          projectVec(p.v, p.alt, vproj);
          if (vproj.z < -0.05) continue;
          var gap = flightP - t;
          var headGlow = gap < 0.09 ? 1 - gap / 0.09 : 0;
          alpha = 0.3 + headGlow * 0.65;
          sz = dotBase * (1.0 + headGlow * 1.3);
          ctx.fillStyle = 'rgba(' + accentRGB + ',' + alpha.toFixed(3) + ')';
          ctx.fillRect(cx + vproj.x * R - sz, cy + vproj.y * R - sz, sz * 2, sz * 2);
        }
        // endpoints: Pittsburgh marker, Bangkok pulses on arrival
        projectVec(route[0].v, 1, vproj);
        if (vproj.z > -0.05) {
          sz = dotBase * 2.0;
          ctx.fillStyle = 'rgba(' + accentRGB + ',0.9)';
          ctx.fillRect(cx + vproj.x * R - sz, cy + vproj.y * R - sz, sz * 2, sz * 2);
        }
        if (flightP >= 1) {
          projectVec(route[ROUTE_N].v, 1, vproj);
          if (vproj.z > -0.05) {
            var pulse = 0.5 + 0.5 * Math.sin(now / 300);
            sz = dotBase * (2.0 + pulse * 0.8);
            ctx.fillStyle = 'rgba(' + accentRGB + ',0.95)';
            ctx.fillRect(cx + vproj.x * R - sz, cy + vproj.y * R - sz, sz * 2, sz * 2);
            ctx.strokeStyle = 'rgba(' + accentRGB + ',' + (0.5 * (1 - pulse)).toFixed(3) + ')';
            ctx.lineWidth = dpr;
            ctx.beginPath();
            ctx.arc(cx + vproj.x * R, cy + vproj.y * R, dotBase * (3 + pulse * 6), 0, 6.2832);
            ctx.stroke();
          }
        }
      }

      // Live seasonal surveillance chart: history is fixed (matching the dot
      // cloud), the current season streams in, a rolling average smooths it,
      // and a seasonal-naive forecast (same phase last season, scaled to the
      // current level) anticipates the next rise. New season every loop.
      var chartLoop = -1, chartVals = [], chartAvg = [];
      function rebuildSeries(loop) {
        chartLoop = loop;
        chartVals = historySeries();
        var rnd = mulberry(loop * 9973 + 11);
        var ampC = 0.6 + rnd() * 0.45;
        var i;
        for (i = CH.hist; i < CH.total; i++) {
          chartVals.push(seasonValue(i, i < 2 * CH.period ? AMP_B : ampC, rnd));
        }
        chartAvg = [];
        for (i = 0; i < CH.total; i++) {
          var s = 0, n = 0;
          for (var k = Math.max(0, i - 2); k <= i; k++) { s += chartVals[k]; n++; }
          chartAvg.push(s / n);
        }
      }
      var chP = { x: 0, y: 0 };
      function chartPt(i, v, out) {
        out.x = CH.x0 + (i / (CH.total - 1 + CH.fore)) * (CH.x1 - CH.x0);
        out.y = CH.y0 - v * CH.h;
      }

      function drawChartLive(now, cx, cy, R, dotBase) {
        var t = now - roleStartT - 500;
        if (t < 0) return;
        var cycle = CH.stream * CH.stepMs + 1600;
        var loop = Math.floor(t / cycle);
        if (loop !== chartLoop) rebuildSeries(loop);
        var wf = Math.min(CH.total - 1, CH.hist - 1 + (t - loop * cycle) / CH.stepMs);
        var w = Math.floor(wf);
        var i, k;
        // this season's observations (history lives in the dot field)
        for (i = CH.hist; i <= w; i++) {
          chartPt(i, chartVals[i], chP);
          var fresh = (wf - i) < 1 ? 1 - (wf - i) : 0;
          var sz = dotBase * (1.15 + fresh * 1.1);
          ctx.fillStyle = 'rgba(' + accentRGB + ',' + (0.55 + fresh * 0.45).toFixed(3) + ')';
          ctx.fillRect(cx + chP.x * R - sz, cy + chP.y * R - sz, sz * 2, sz * 2);
        }
        // rolling average line across history + this season
        ctx.strokeStyle = 'rgba(' + accentRGB + ',0.85)';
        ctx.lineWidth = dpr * 1.6;
        ctx.beginPath();
        for (i = 0; i <= w; i++) {
          chartPt(i, chartAvg[i], chP);
          if (i === 0) ctx.moveTo(cx + chP.x * R, cy + chP.y * R);
          else ctx.lineTo(cx + chP.x * R, cy + chP.y * R);
        }
        ctx.stroke();
        // "now" cursor
        chartPt(w, 0, chP);
        ctx.strokeStyle = 'rgba(' + accentRGB + ',0.15)';
        ctx.lineWidth = dpr;
        ctx.beginPath();
        ctx.moveTo(cx + chP.x * R, cy + (CH.y0 - CH.h) * R);
        ctx.lineTo(cx + chP.x * R, cy + CH.y0 * R);
        ctx.stroke();
        // seasonal-naive forecast: same phase last season, scaled to the
        // current level, with a widening uncertainty cone
        {
          var last = chartAvg[w];
          var base = chartAvg[w - CH.period];
          var ratio = base > 0.03 ? last / base : 1;
          ratio = Math.max(0.5, Math.min(1.8, ratio));
          var fx = [], fy = [], up = [], dn = [];
          for (k = 1; k <= CH.fore; k++) {
            var v = Math.max(0.02, chartAvg[w + k - CH.period] * ratio);
            chartPt(w + k, v, chP);
            fx.push(chP.x); fy.push(chP.y);
            up.push(chP.y - (0.014 + 0.012 * k));
            dn.push(Math.min(CH.y0, chP.y + (0.014 + 0.012 * k)));
          }
          ctx.fillStyle = 'rgba(' + accentRGB + ',0.07)';
          ctx.beginPath();
          chartPt(w, last, chP);
          ctx.moveTo(cx + chP.x * R, cy + chP.y * R);
          for (k = 0; k < CH.fore; k++) ctx.lineTo(cx + fx[k] * R, cy + up[k] * R);
          for (k = CH.fore - 1; k >= 0; k--) ctx.lineTo(cx + fx[k] * R, cy + dn[k] * R);
          ctx.closePath();
          ctx.fill();
          ctx.strokeStyle = 'rgba(' + accentRGB + ',0.55)';
          ctx.lineWidth = dpr * 1.2;
          ctx.setLineDash([4 * dpr, 4 * dpr]);
          ctx.beginPath();
          chartPt(w, last, chP);
          ctx.moveTo(cx + chP.x * R, cy + chP.y * R);
          for (k = 0; k < CH.fore; k++) ctx.lineTo(cx + fx[k] * R, cy + fy[k] * R);
          ctx.stroke();
          ctx.setLineDash([]);
        }
      }

      // Roaming inference signal: every cycle a new random input→hidden→output
      // path lights up and a comet travels it
      function drawNet(now, cx, cy, R, dotBase) {
        if (!netLayers) return;
        var CYC = 1500;
        var t = now - roleStartT;
        if (t < 400) return;
        t -= 400;
        var cyc = Math.floor(t / CYC);
        var rnd = mulberry(cyc * 7919 + 3);
        var A = netLayers[0][Math.floor(rnd() * netLayers[0].length)];
        var B = netLayers[1][Math.floor(rnd() * netLayers[1].length)];
        var C = netLayers[2][0];
        var s = (t % CYC) / CYC;
        // traversed edges glow
        ctx.lineWidth = dpr;
        ctx.strokeStyle = 'rgba(' + accentRGB + ',' + (s < 0.5 ? 0.35 : 0.15) + ')';
        ctx.beginPath();
        ctx.moveTo(cx + A.x * R, cy + A.y * R);
        ctx.lineTo(cx + B.x * R, cy + B.y * R);
        ctx.stroke();
        ctx.strokeStyle = 'rgba(' + accentRGB + ',' + (s >= 0.5 ? 0.35 : 0.12) + ')';
        ctx.beginPath();
        ctx.moveTo(cx + B.x * R, cy + B.y * R);
        ctx.lineTo(cx + C.x * R, cy + C.y * R);
        ctx.stroke();
        // comet with a short trail
        for (var k = 0; k < 6; k++) {
          var ss = s - k * 0.022;
          if (ss < 0) break;
          var px, py, u;
          if (ss < 0.5) { u = ss / 0.5; px = A.x + (B.x - A.x) * u; py = A.y + (B.y - A.y) * u; }
          else { u = (ss - 0.5) / 0.5; px = B.x + (C.x - B.x) * u; py = B.y + (C.y - B.y) * u; }
          var al = (1 - k / 6) * 0.95;
          var sz = dotBase * (2.0 - k * 0.22);
          ctx.fillStyle = 'rgba(' + accentRGB + ',' + al.toFixed(3) + ')';
          ctx.fillRect(cx + px * R - sz, cy + py * R - sz, sz * 2, sz * 2);
        }
        // node glow as the signal hands off
        var stations = [[A, 0.03], [B, 0.5], [C, 0.97]];
        for (k = 0; k < 3; k++) {
          var dd = Math.abs(s - stations[k][1]);
          if (dd < 0.1) {
            var g = 1 - dd / 0.1;
            var gsz = dotBase * (2 + g * 2.2);
            ctx.fillStyle = 'rgba(' + accentRGB + ',' + (0.4 * g).toFixed(3) + ')';
            ctx.fillRect(cx + stations[k][0].x * R - gsz, cy + stations[k][0].y * R - gsz, gsz * 2, gsz * 2);
          }
        }
      }

      function drawTrace(now, cx, cy, R, dotBase) {
        var t = now - roleStartT;
        ctx.lineWidth = dpr * 1.5;
        for (var k = 0; k < traceNodes.length; k++) {
          var n = traceNodes[k];
          var age = t - n.act;
          if (age < 0) continue;
          var px = cx + n.x * R, py = cy + n.y * R;
          // link draws from parent over 320 ms, then stays lit
          if (k > 0) {
            var par = traceNodes[n.parent];
            var lp = Math.min(1, age / 320);
            ctx.strokeStyle = 'rgba(' + accentRGB + ',' + (lp === 1 ? 0.45 : 0.7).toFixed(2) + ')';
            ctx.beginPath();
            ctx.moveTo(cx + par.x * R, cy + par.y * R);
            ctx.lineTo(cx + (par.x + (n.x - par.x) * lp) * R, cy + (par.y + (n.y - par.y) * lp) * R);
            ctx.stroke();
          }
          // node
          var sz = dotBase * (k === 0 ? 2.4 : 1.7);
          ctx.fillStyle = 'rgba(' + accentRGB + ',0.95)';
          ctx.fillRect(px - sz, py - sz, sz * 2, sz * 2);
          // expanding detection ring
          if (age < 700) {
            var rp = age / 700;
            ctx.strokeStyle = 'rgba(' + accentRGB + ',' + (0.55 * (1 - rp)).toFixed(3) + ')';
            ctx.beginPath();
            ctx.arc(px, py, dotBase * 2 + rp * R * 0.07, 0, 6.2832);
            ctx.stroke();
          }
        }
      }

      function drawFrame(now) {
        ctx.clearRect(0, 0, cw, ch);
        var R = Math.min(cw, ch) * 0.5;
        var cx = cw / 2, cy = ch / 2;
        var dotBase = Math.max(dpr * 0.55, R * 0.0055);
        for (var i = 0; i < dots.length; i++) {
          var d = dots[i];
          if (d.a < 0.015) continue;
          ctx.fillStyle = 'rgba(' + accentRGB + ',' + Math.min(1, d.a).toFixed(3) + ')';
          var s = dotBase * d.size * d.jitter;
          ctx.fillRect(cx + d.x * R - s, cy + d.y * R - s, s * 2, s * 2);
        }
        if (activeRole === 'travel' && (mode === 'globe' || mode === 'toglobe')) {
          drawFlights(now, cx, cy, R, dotBase);
        }
        if (activeRole === 'health' && mode === 'shape' && !reduceMotionGlobe) {
          drawTrace(now, cx, cy, R, dotBase);
        }
        if (activeRole === 'data' && mode === 'shape' && !reduceMotionGlobe) {
          drawChartLive(now, cx, cy, R, dotBase);
        }
        if (activeRole === 'ai' && mode === 'shape' && !reduceMotionGlobe) {
          drawNet(now, cx, cy, R, dotBase);
        }
      }

      // ── rAF loop ──
      var running = false, rafId = 0, lastFrameT = 0, inView = true;

      function globeTick() {
        rafId = 0;
        var now = performance.now();
        var dt = Math.min(48, Math.max(1, now - lastFrameT));
        lastFrameT = now;
        updateDots(now, dt);
        drawFrame(now);
        var needsMotion = !reduceMotionGlobe || mode !== 'globe';
        if (running && inView && !document.hidden && needsMotion) {
          rafId = requestAnimationFrame(globeTick);
        } else {
          running = false;
        }
      }

      function startGlobe() {
        if (document.hidden || !inView) return;
        if (reduceMotionGlobe && mode === 'globe') {
          var now = performance.now();
          updateDots(now, 16);
          drawFrame(now);
          return;
        }
        if (running) return;
        running = true;
        lastFrameT = performance.now();
        rafId = requestAnimationFrame(globeTick);
      }

      function stopGlobe() {
        if (rafId) cancelAnimationFrame(rafId);
        rafId = 0;
        running = false;
      }

      // ── Role sync ──
      document.addEventListener('rolechange', function (ev) {
        activeRole = ev.detail.key;
        rolePending = true;
        if (activeRole === 'travel') {
          // zoom into the network's output node; the globe blooms from it
          var out = netLayers && netLayers[2] && netLayers[2][0];
          beginReturnToGlobe(out ? { x: out.x, y: out.y } : null);
        }
        else if (activeRole === 'health') {
          // zoom from the globe into Thailand, anchored on Bangkok
          var anchor = projectVec(sphereVec(BKK.lat, BKK.lon), 1, { x: 0, y: 0, z: 0 });
          beginTween('thailand', 'shape', { x: anchor.x, y: anchor.y });
        }
        else if (activeRole === 'data') beginTween('chart', 'shape', null, true);
        else beginTween('network');
        startGlobe();
      });

      document.addEventListener('visibilitychange', function () {
        if (document.hidden) stopGlobe(); else startGlobe();
      });

      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function (entries) {
          inView = entries[0].isIntersecting;
          if (inView) startGlobe(); else stopGlobe();
        }).observe(canvas.parentElement);
      }

      if ('ResizeObserver' in window) {
        new ResizeObserver(resizeGlobe).observe(canvas.parentElement);
      } else {
        window.addEventListener('resize', resizeGlobe);
      }

      resizeGlobe();
      startGlobe();
    })();

    // ── Hero Role Cycle ──
    // Conductor for the four-identity "bridge": retypes the accent phrase in
    // the hero line (typewriter with cursor) and broadcasts 'rolechange' on
    // document so the dot canvas can morph in sync.
    (function () {
      var container = document.getElementById('roleSwap');
      if (!container) return;
      var word = container.querySelector('.role-word');
      if (!word) return;
      var paragraph = container.closest('.hero-positioning');

      var ROLES = [
        { label: 'travel medicine', key: 'travel' },
        { label: 'public health', key: 'health' },
        { label: 'data analysis', key: 'data' },
        { label: 'AI engineering', key: 'ai' }
      ];
      var ROLE_PERIOD = 6000;
      var roleIndex = 0;
      var reduceMotionRoles = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Reserve the tallest possible wrap (measured, not guessed) so retyping
      // a shorter/longer role never reflows the line count and shifts the
      // page below the hero. font-size is fluid (vw clamp), so this is
      // re-measured on resize rather than fixed at a CSS breakpoint.
      function reserveMaxHeight() {
        if (!paragraph) return;
        paragraph.style.minHeight = '';
        var original = word.textContent;
        var max = 0;
        for (var i = 0; i < ROLES.length; i++) {
          word.textContent = ROLES[i].label;
          max = Math.max(max, paragraph.getBoundingClientRect().height);
        }
        word.textContent = original;
        paragraph.style.minHeight = max + 'px';
      }
      reserveMaxHeight();
      window.addEventListener('load', reserveMaxHeight);
      var resizeTimer = 0;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(reserveMaxHeight, 150);
      });

      var typeTimer = 0;
      function typeSwap(nextIndex) {
        clearTimeout(typeTimer);
        roleIndex = nextIndex;
        var target = ROLES[nextIndex].label;
        document.dispatchEvent(new CustomEvent('rolechange', {
          detail: { index: nextIndex, key: ROLES[nextIndex].key, label: target }
        }));
        container.classList.add('typing');
        function erase() {
          var cur = word.textContent;
          if (cur.length) {
            word.textContent = cur.slice(0, -1);
            typeTimer = setTimeout(erase, 26 + Math.random() * 18);
          } else {
            typeTimer = setTimeout(type, 260);
          }
        }
        function type() {
          var cur = word.textContent;
          if (cur.length < target.length) {
            word.textContent = target.slice(0, cur.length + 1);
            typeTimer = setTimeout(type, 42 + Math.random() * 38);
          } else {
            container.classList.remove('typing');
          }
        }
        erase();
      }

      var heroVisible = true, hovering = false;
      container.addEventListener('mouseenter', function () { hovering = true; });
      container.addEventListener('mouseleave', function () { hovering = false; });
      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function (entries) {
          heroVisible = entries[0].isIntersecting;
        }).observe(container);
      }

      if (!reduceMotionRoles) {
        setInterval(function () {
          if (document.hidden || !heroVisible || hovering) return;
          typeSwap((roleIndex + 1) % ROLES.length);
        }, ROLE_PERIOD);
      }
    })();
</script>
